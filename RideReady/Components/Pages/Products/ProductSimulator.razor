@using Radzen.Blazor
@using RepositoryLibrary.Features.Products
@using RepositoryLibrary.Features.Products.Entities
@using RepositoryLibrary.Features.Products.Interfaces
@using RepositoryLibrary.Features.Purchases
@using RepositoryLibrary.Features.Purchases.Entities
@using RepositoryLibrary.Features.Purchases.Enums
@using RepositoryLibrary.Features.Purchases.Interfaces
@using RepositoryLibrary.Features.Purchases.Snapshot
@using RepositoryLibrary.Services
@rendermode InteractiveServer
@inject IProductService ProductService
@inject IPurchaseService PurchaseService

<RadzenCard Style="padding: 1rem">
    <div class="simulator-shell">
        <div class="simulator-heading">
            <div>
                <h3 class="simulator-title">Purchase simulator</h3>
                <p class="simulator-subtitle">Choose the product and quantity to preview the purchase impact for @_mockUserId.</p>
            </div>

            @if (_products != null)
            {
                <span class="simulator-count">@_products.Count active product@(_products.Count != 1 ? "s" : "")</span>
            }
        </div>

        @if (_loading)
        {
            <p>Loading...</p>
        }
        else if (_products?.Any() == true)
        {
            <div class="simulator-grid">
                <section class="purchase-flow" aria-label="Products available to purchase">
                    <div class="subscription-card">
                        <div class="section-label">
                            <span>Monthly subscription</span>
                            <span class="purchase-badge subscription">Monthly</span>
                        </div>

                        @if (_subscriptionProducts.Any())
                        {
                            <select class="subscription-select"
                                    @bind="_selectedSubscriptionId"
                                    @bind:after="ClearSimulation">
                                <option value="">No monthly pass</option>
                                @foreach (var product in _subscriptionProducts)
                                {
                                    <option value="@product.Id">
                                        @product.Name - @GetEntitlementSummary(product) - @product.Price.ToString("C")
                                    </option>
                                }
                            </select>

                            <div class="subscription-controls">
                                <label class="month-field">
                                    <span>Start month</span>
                                    <input type="month"
                                           class="month-input"
                                           @bind="_subscriptionStartMonth"
                                           @bind:format="yyyy-MM"
                                           @bind:after="ClearSimulation" />
                                </label>

                                <div class="quantity-row">
                                    <span>Months</span>
                                    <div class="quantity-control" aria-label="Subscription months">
                                        <button type="button" class="quantity-button" @onclick="DecreaseSubscriptionMonths" disabled="@(_subscriptionMonths <= 1)">-</button>
                                        <span class="quantity-value">@_subscriptionMonths</span>
                                        <button type="button" class="quantity-button" @onclick="IncreaseSubscriptionMonths">+</button>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <p class="empty-state">No weekly subscription products available.</p>
                        }
                    </div>

                    <div class="pack-list">
                        <div class="section-label">
                            <span>Packs</span>
                            <span class="purchase-badge pack">Pack</span>
                        </div>

                        @if (_packProducts.Any())
                        {
                            @foreach (var product in _packProducts)
                            {
                                var quantity = GetPackQuantity(product.Id);
                                var lineTotal = product.Price * quantity;

                                <div class="pack-row">
                                    <div class="pack-info">
                                        <span class="simulator-product-name">@product.Name</span>
                                        <span class="simulator-product-meta">@GetEntitlementSummary(product)</span>
                                        <span class="simulator-product-price">@product.Price.ToString("C") each</span>
                                    </div>

                                    <div class="pack-actions">
                                        <div class="quantity-control" aria-label="@($"{product.Name} quantity")">
                                            <button type="button" class="quantity-button" @onclick="() => DecreasePackQuantity(product.Id)" disabled="@(quantity <= 0)">-</button>
                                            <span class="quantity-value">@quantity</span>
                                            <button type="button" class="quantity-button" @onclick="() => IncreasePackQuantity(product.Id)">+</button>
                                        </div>
                                        <strong class="pack-total">@lineTotal.ToString("C")</strong>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="empty-state">No pack products available.</p>
                        }
                    </div>
                </section>

                <section class="purchase-panel" aria-label="Purchase summary">
                    @{
                        var weeklyTotal = GetSelectedWeeklyTotal();
                        var creditTotal = GetSelectedCreditTotal();
                        var oneOffTotal = GetSelectedPackTotal();
                        var recurringTotal = SelectedSubscription?.Price ?? 0;
                        var subscriptionTotal = GetSelectedSubscriptionTotal();
                        var totalNow = subscriptionTotal + oneOffTotal;
                    }

                    <div class="selected-summary">
                        <span class="purchase-badge subscription">Preview</span>
                        <h4>Entitlement preview</h4>
                        <p>@GetSelectionSummary()</p>
                    </div>

                    <div class="simulation-lines">
                        <div class="simulation-line">
                            <span>Total now</span>
                            <strong>@totalNow.ToString("C")</strong>
                        </div>
                        <div class="simulation-line">
                            <span>Subscription months</span>
                            <strong>@subscriptionTotal.ToString("C")</strong>
                        </div>
                        <div class="simulation-line">
                            <span>Monthly value</span>
                            <strong>@recurringTotal.ToString("C")</strong>
                        </div>
                        <div class="simulation-line">
                            <span>Pack total</span>
                            <strong>@oneOffTotal.ToString("C")</strong>
                        </div>
                    </div>

                    <div class="entitlement-preview">
                        <div>
                            <span class="preview-value">@weeklyTotal</span>
                            <span class="preview-label">lesson@((weeklyTotal != 1) ? "s" : "") per week</span>
                        </div>
                        <div>
                            <span class="preview-value">@creditTotal</span>
                            <span class="preview-label">credit@((creditTotal != 1) ? "s" : "") granted</span>
                        </div>
                    </div>

                    <button type="button" class="simulate-button" @onclick="CreatePurchaseRequest">
                        Create purchase request
                    </button>

                    @if (_currentPurchase?.Status == PurchaseStatus.PendingPayment)
                    {
                        <div class="purchase-actions">
                            <button type="button" class="simulate-button secondary" @onclick="ConfirmPayment">
                                Mark as paid
                            </button>
                            <button type="button" class="simulate-button danger" @onclick="CancelPurchase">
                                Cancel request
                            </button>
                        </div>
                    }

                    @if (_lastSimulation is not null)
                    {
                        <div class="simulation-result" role="status">
                            @_lastSimulation
                        </div>
                    }

                    @if (_cartItems.Any())
                    {
                        <div class="cart-preview" aria-label="Simulated cart">
                            <strong>Purchase request @(_currentPurchase is not null ? $"#{_currentPurchase.Id} - {_currentPurchase.Status}" : "")</strong>
                            @foreach (var item in _cartItems)
                            {
                                <div class="cart-line">
                                    <span>@GetCartLineLabel(item)</span>
                                    <span>@item.Total.ToString("C")</span>
                                </div>
                            }
                        </div>
                    }

                    @if (_entitlementSnapshot is not null && (_entitlementSnapshot.Subscriptions.Any() || _entitlementSnapshot.CreditLedgerEntries.Any()))
                    {
                        <div class="cart-preview" aria-label="Provisioned entitlements">
                            <strong>Provisioned entitlements</strong>

                            @foreach (var subscription in _entitlementSnapshot.Subscriptions)
                            {
                                <div class="cart-line">
                                    <span>@subscription.Product.Name (@($"{subscription.PeriodStart:yyyy-MM-dd} to {subscription.PeriodEnd:yyyy-MM-dd}"))</span>
                                    <span>@string.Join(", ", subscription.Entitlements.Select(e => $"{e.LessonType.Name}: {e.WeeklyFrequency}x/week"))</span>
                                </div>
                            }

                            @foreach (var credit in _entitlementSnapshot.CreditLedgerEntries)
                            {
                                <div class="cart-line">
                                    <span>@credit.LessonType.Name credits</span>
                                    <span>@credit.CreditsDelta</span>
                                </div>
                            }
                        </div>
                    }
                </section>
            </div>
        }
        else
        {
            <p>No active products available.</p>
        }
    </div>
</RadzenCard>

@code {
    private List<Product>? _products;
    private List<Product> _subscriptionProducts = new();
    private List<Product> _packProducts = new();
    private Dictionary<int, int> _packQuantities = new();
    private List<CartLine> _cartItems = new();
    private Purchase? _currentPurchase;
    private PurchaseEntitlementSnapshot? _entitlementSnapshot;
    private const string _mockUserId = "mock-identity-user-001";
    private int? _selectedSubscriptionId;
    private int _subscriptionMonths = 1;
    private DateTime _subscriptionStartMonth = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private bool _loading = true;
    private string? _lastSimulation;

    private Product? SelectedSubscription => _subscriptionProducts.FirstOrDefault(p => p.Id == _selectedSubscriptionId);

    protected override async Task OnInitializedAsync()
    {
        _products = (await ProductService.GetAll())
            .Where(p => p.IsActive)
            .OrderBy(p => GetPurchaseKind(p).SortOrder)
            .ThenBy(p => p.Name)
            .ToList();

        _subscriptionProducts = _products
            .Where(IsSubscription)
            .OrderBy(p => p.Name)
            .ToList();

        _packProducts = _products
            .Where(p => !IsSubscription(p))
            .OrderBy(p => p.Name)
            .ToList();

        _selectedSubscriptionId = _subscriptionProducts.FirstOrDefault()?.Id;
        _packQuantities = _packProducts.ToDictionary(p => p.Id, _ => 0);
        await RefreshEntitlements();
        _loading = false;
    }

    private void DecreasePackQuantity(int productId)
    {
        if (GetPackQuantity(productId) <= 0) return;

        _packQuantities[productId] = GetPackQuantity(productId) - 1;
        ClearSimulation();
    }

    private void IncreasePackQuantity(int productId)
    {
        _packQuantities[productId] = GetPackQuantity(productId) + 1;
        ClearSimulation();
    }

    private int GetPackQuantity(int productId)
        => _packQuantities.TryGetValue(productId, out var quantity) ? quantity : 0;

    private void DecreaseSubscriptionMonths()
    {
        if (_subscriptionMonths <= 1) return;

        _subscriptionMonths--;
        ClearSimulation();
    }

    private void IncreaseSubscriptionMonths()
    {
        _subscriptionMonths++;
        ClearSimulation();
    }

    private void ClearSimulation()
    {
        _lastSimulation = null;
        _cartItems.Clear();
        _currentPurchase = null;
    }

    private async Task CreatePurchaseRequest()
    {
        var requestLines = BuildPurchaseRequestLines();

        if (!requestLines.Any())
        {
            _lastSimulation = "Select a monthly subscription or at least one pack to create a purchase request.";
            return;
        }

        _currentPurchase = await PurchaseService.CreatePendingPurchase(_mockUserId, requestLines);
        _cartItems = _currentPurchase.Lines.Select(ToCartLine).ToList();

        _lastSimulation = $"Purchase request #{_currentPurchase.Id} created with status {_currentPurchase.Status}. No entitlements were provisioned yet.";
    }

    private async Task ConfirmPayment()
    {
        if (_currentPurchase is null) return;

        _currentPurchase = await PurchaseService.ConfirmPayment(_currentPurchase.Id);
        await RefreshEntitlements();

        _lastSimulation = _currentPurchase is null
            ? "Purchase request not found."
            : $"Purchase request #{_currentPurchase.Id} marked as paid. Entitlements were provisioned.";
    }

    private async Task CancelPurchase()
    {
        if (_currentPurchase is null) return;

        _currentPurchase = await PurchaseService.CancelPurchase(_currentPurchase.Id);
        _lastSimulation = _currentPurchase is null
            ? "Purchase request not found."
            : $"Purchase request #{_currentPurchase.Id} cancelled. No entitlements were provisioned.";
    }

    private List<PurchaseRequestLine> BuildPurchaseRequestLines()
    {
        var lines = new List<PurchaseRequestLine>();

        if (SelectedSubscription is not null)
        {
            var period = GetSelectedSubscriptionPeriod();
            lines.Add(new PurchaseRequestLine(
                SelectedSubscription,
                PurchaseLineKind.Subscription,
                _subscriptionMonths,
                period.Start,
                period.End));
        }

        lines.AddRange(_packProducts
            .Select(product => new { Product = product, Quantity = GetPackQuantity(product.Id) })
            .Where(item => item.Quantity > 0)
            .Select(item => new PurchaseRequestLine(
                item.Product,
                PurchaseLineKind.CreditPack,
                item.Quantity)));

        return lines;
    }

    private async Task RefreshEntitlements()
        => _entitlementSnapshot = await PurchaseService.GetEntitlementsForUser(_mockUserId);

    private int GetSelectedWeeklyTotal()
        => SelectedSubscription?.Entitlements?.Sum(e => e.WeeklyFrequency ?? 0) ?? 0;

    private int GetSelectedCreditTotal()
        => _packProducts.Sum(product => (product.Entitlements?.Sum(e => e.CreditsGranted ?? 0) ?? 0) * GetPackQuantity(product.Id));

    private decimal GetSelectedPackTotal()
        => _packProducts.Sum(product => product.Price * GetPackQuantity(product.Id));

    private decimal GetSelectedSubscriptionTotal()
        => (SelectedSubscription?.Price ?? 0) * _subscriptionMonths;

    private string GetSelectionSummary()
    {
        var selectedPacks = _packProducts.Count(product => GetPackQuantity(product.Id) > 0);

        var packSuffix = selectedPacks != 1 ? "s" : "";

        return (SelectedSubscription, selectedPacks) switch
        {
            (not null, > 0) => $"{SelectedSubscription.Name} for {GetSelectedSubscriptionPeriodLabel()} plus {selectedPacks} pack type{packSuffix} selected.",
            (not null, _) => $"{SelectedSubscription.Name} for {GetSelectedSubscriptionPeriodLabel()}",
            (null, > 0) => $"{selectedPacks} pack type{packSuffix} selected.",
            _ => "No products selected."
        };
    }

    private (DateOnly Start, DateOnly End) GetSelectedSubscriptionPeriod()
    {
        var start = new DateOnly(_subscriptionStartMonth.Year, _subscriptionStartMonth.Month, 1);
        var end = start.AddMonths(_subscriptionMonths).AddDays(-1);
        return (start, end);
    }

    private string GetSelectedSubscriptionPeriodLabel()
    {
        var period = GetSelectedSubscriptionPeriod();
        var monthSuffix = _subscriptionMonths != 1 ? "s" : "";
        return $"{_subscriptionMonths} month{monthSuffix} ({period.Start:yyyy-MM-dd} to {period.End:yyyy-MM-dd})";
    }

    private static string GetCartLineLabel(CartLine item)
    {
        if (item.Kind == PurchaseLineKind.Subscription && item.PeriodStart is not null && item.PeriodEnd is not null)
        {
            var monthSuffix = item.Quantity != 1 ? "s" : "";
            return $"{item.Quantity} month{monthSuffix} x {item.Name} ({item.PeriodStart:yyyy-MM-dd} to {item.PeriodEnd:yyyy-MM-dd})";
        }

        return $"{item.Quantity} x {item.Name}";
    }

    private static CartLine ToCartLine(PurchaseLine line)
        => new(
            line.Purchase.UserId,
            line.ProductName,
            line.Quantity,
            line.LineTotal,
            line.Kind,
            line.SubscriptionPeriodStart,
            line.SubscriptionPeriodEnd);

    private static bool IsSubscription(Product product)
        => product.Entitlements?.Any(e => (e.WeeklyFrequency ?? 0) > 0) == true;

    private static (string Label, string CssClass, int SortOrder) GetPurchaseKind(Product product)
    {
        if (IsSubscription(product))
        {
            return ("Monthly", "subscription", 0);
        }

        return ("Pack", "pack", 1);
    }

    private static string GetEntitlementSummary(Product product)
    {
        if (product.Entitlements?.Any() != true)
        {
            return "No entitlements";
        }

        return string.Join(", ", product.Entitlements.Select(e =>
        {
            var lessonType = e.LessonType?.Name ?? "Lesson";

            if ((e.WeeklyFrequency ?? 0) > 0)
            {
                return $"{lessonType}: {e.WeeklyFrequency}x/week";
            }

            if ((e.CreditsGranted ?? 0) > 0)
            {
                return $"{lessonType}: {e.CreditsGranted} credits";
            }

            return $"{lessonType}: unlimited";
        }));
    }

    private sealed record CartLine(
        string UserId,
        string Name,
        int Quantity,
        decimal Total,
        PurchaseLineKind Kind,
        DateOnly? PeriodStart,
        DateOnly? PeriodEnd);
}
