@page "/"
@page "/home"
@using RideReady.Components.Layout
@layout EmptyLayout

<section class="landing">

    @* --- Foto de fundo (animacao em CSS puro, sempre visivel) --- *@
    <div class="landing-photo">
        <img class="landing-img" src="/Images/Cavalo_1.jpg" alt="Cavalo a saltar numa escola de equitacao" />
        <div class="landing-overlay"></div>
    </div>

    @* --- Barra de topo --- *@
    <nav class="landing-nav">
        <a class="landing-brand" href="/">
            <img src="/favicon.png" alt="RideReady" />
            <span class="landing-brand-name">RideReady</span>
        </a>
        <div class="landing-nav-actions">
            <a class="landing-link" href="/Account/Login">Entrar</a>
            <a class="landing-cta" href="/Account/Register">Criar conta</a>
        </div>
    </nav>

    @* --- Conteudo do heroi --- *@
    <div class="landing-content">
        <span class="rr-eyebrow landing-kicker">Escola de equitação</span>
        <h1 class="landing-title">Do estábulo à sela,<br />sem papelada.</h1>
        <p class="landing-sub">
            Marcação de aulas, gestão de alunos e cavalos, pagamentos:
            tudo num só sítio, pensado para a tua escola.
        </p>
        <div class="landing-buttons">
            <a class="landing-cta landing-cta-lg" href="/Account/Register">Criar conta →</a>
            <a class="landing-ghost" href="/Account/Login">Entrar</a>
        </div>

        @* --- Para quem e: tres perfis --- *@
        <div class="landing-roles rr-glass-dark">
            <div class="landing-role">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3l7 3v5c0 4-3 7-7 8-4-1-7-4-7-8V6l7-3z" />
                </svg>
                <span>Administradores</span>
            </div>
            <div class="landing-role-div"></div>
            <div class="landing-role">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="8" r="3.5" />
                    <path d="M5 20c0-3.5 3-5.5 7-5.5s7 2 7 5.5" />
                </svg>
                <span>Professores</span>
            </div>
            <div class="landing-role-div"></div>
            <div class="landing-role">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 9l10-4 10 4-10 4L2 9z" />
                    <path d="M6 11v4c0 1.5 2.7 2.5 6 2.5s6-1 6-2.5v-4" />
                </svg>
                <span>Alunos</span>
            </div>
        </div>
    </div>

    <footer class="landing-foot">© 2026 RideReady</footer>
</section>

