@page "/admin/payments/{studentId}"
@page "/student/payments/{studentId}"
@using Radzen
@using Radzen.Blazor
@using RepositoryLibrary.Features.Purchases
@using RepositoryLibrary.Features.Purchases.Entities
@using RepositoryLibrary.Features.Purchases.Interfaces
@using RepositoryLibrary.Features.Users.Interfaces
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject DialogService DialogService
@inject IUserService UserService
@inject IPurchaseService PurchaseService

<RadzenStack Gap="1.5rem">

    <!-- HEADER -->
    <RadzenCard>
        <RadzenStack Gap="0.5rem">

            <h3>@_studentName</h3>
            <span>@_studentEmail</span>

            <RadzenStack Orientation="Orientation.Horizontal" Gap="2rem" Style="margin-top:1rem">

                <div>
                    <b>Active Subscription</b><br />
                    <span>@_activeSubscription</span>
                </div>

                <div>
                    <b>Credits</b><br />
                    <span>@_credits</span>
                </div>

                <div>
                    <b>Total Spent</b><br />
                    <span>@_totalSpent €</span>
                </div>

            </RadzenStack>

        </RadzenStack>
    </RadzenCard>

    <!-- ACTION BAR -->
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween">

        <RadzenButton Icon="add"
                      Text="New Purchase"
                      ButtonStyle="ButtonStyle.Primary"
                      Click="@CreatePurchase" />

    </RadzenStack>

    <!-- PURCHASE GRID -->
    <RadzenDataGrid Data="@_purchases"
                    TItem="Purchase"
                    AllowPaging="true"
                    PageSize="10">

        <Columns>

            <RadzenDataGridColumn TItem="Purchase"
                                  Property="PurchasedAtUtc"
                                  Title="Date" />

            <RadzenDataGridColumn TItem="Purchase"
                                  Property="Status"
                                  Title="Status" />

            <RadzenDataGridColumn TItem="Purchase"
                                  Property="TotalAmount"
                                  Title="Total (€)" />

            <RadzenDataGridColumn TItem="Purchase"
                                  Title="Subscription (€)">
                <Template Context="p">
                    @p.MonthlyRecurringAmount
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Purchase"
                                  Title="Credits (€)">
                <Template Context="p">
                    @p.OneOffAmount
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Purchase"
                                  Title="Actions"
                                  Width="120px"
                                  TextAlign="TextAlign.Center">

                <Template Context="p">
                    <RadzenButton Icon="visibility"
                                  Size="ButtonSize.Small"
                                  ButtonStyle="ButtonStyle.Light"
                                  Click="@(() => ViewPurchase(p.Id))" />
                </Template>

            </RadzenDataGridColumn>

        </Columns>

    </RadzenDataGrid>

</RadzenStack>

@code {

    [Parameter]
    public string StudentId { get; set; } = null!;

    private string? _studentName;
    private string? _studentEmail;

    private decimal _totalSpent;
    private string _activeSubscription = "-";
    private int _credits = 0;

    private List<Purchase> _purchases = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadStudent();
        await LoadPurchases();
        CalculateSummary();
    }

    private async Task LoadStudent()
    {
        var student = await UserService.GetUserById(StudentId);

        _studentName = student.UserName;
        _studentEmail = student.Email;
    }

    private async Task LoadPurchases()
    {
        _purchases = await PurchaseService.GetPurchasesByUserId(StudentId);

    }

    private void CalculateSummary()
    {
        _totalSpent = _purchases.Sum(x => x.TotalAmount);
    }


    private async Task ViewPurchase(int purchaseId)
    {
        var purchase = await PurchaseService.GetByPurchaseId(purchaseId);

        if (purchase is null)
            throw new Exception("Purchase not found.");

        var model = new CreatePaymentDialogModel
        {
            
            UserId = purchase.UserId,

            Lines = purchase.Lines
                .Select(l => new PurchaseRequestLine(
                    new Product
                    {
                        Id = l.ProductId,
                        Name = l.ProductName,
                        Price = l.UnitPrice,
                    },
                    l.Kind,
                    l.Quantity,
                    l.SubscriptionPeriodStart,
                    l.SubscriptionPeriodEnd
                ))
                .ToList(),

            PaymentReceived =
                purchase.Status != PurchaseStatus.PendingPayment
        };

        var result = await DialogService.OpenAsync<PaymentDialog>(
            "Pagamento",
            new Dictionary<string, object>
            {
            { "Model", model }
            },
            new DialogOptions
            {
                Width = "600px",
                Height = "auto"
            });

        if (result is PaymentDialog.PaymentDialogResult r)
        {
            if (r.PaymentStatusChanged && r.PaymentReceived)
            {
                await PurchaseService.ConfirmPayment(purchaseId);

                await LoadPurchases();

                CalculateSummary();

                StateHasChanged();
            }
        }
    }

    




    private void CreatePurchase()
    {
        Navigation.NavigateTo($"/students/payments/{StudentId}/new");
    }
}
