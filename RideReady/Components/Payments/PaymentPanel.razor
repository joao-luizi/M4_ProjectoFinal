@using RepositoryLibrary.Models

@if (Student != null)
{
    <RadzenCard>

        <h4>@Student.Name</h4>

        @foreach (var line in PackageLines)
        {
            <div class="package-line"
                 style="display:flex; gap:10px; align-items:center; margin-bottom:10px;">

                <div style="flex:3;">
                    <b>@line.DisplayName</b>
                    <div style="font-size:12px; opacity:0.7;">
                        @line.Details
                    </div>
                </div>

                <div style="flex:1;">
                    € @line.BaseValue
                </div>

                <RadzenNumeric TValue="int"
                               Min="0"
                               @bind-Value="line.Quantity"
                               Style="width:120px" />

                <div style="flex:1;">
                    € @line.Total
                </div>
            </div>
        }

        <div style="display:flex; justify-content:space-between; align-items:center; margin-top:20px;">

            <div style="font-size:16px;">
                <b>Total:</b> € @GrandTotal
            </div>

            <div style="display:flex; gap:10px;">
                <RadzenButton Text="Create"
                              Disabled="@(GrandTotal == 0)"
                              Click="@HandleSubmit" />

                <RadzenButton Text="Close"
                              Click="@OnClose" />
            </div>

        </div>

    </RadzenCard>
}

@code {
    [Parameter] public AdminPayments.StudentViewModel? Student { get; set; }
    [Parameter] public List<Package> Packages { get; set; } = new();

    [Parameter] public EventCallback OnClose { get; set; }

   
    [Parameter] public EventCallback<List<PackageLineInput>> OnSubmit { get; set; }

    private List<PackageLineInput> PackageLines = new();

    private decimal GrandTotal =>
        PackageLines.Sum(x => x.Total);

    protected override void OnParametersSet()
    {
        if (Packages == null)
            return;

        PackageLines = Packages
            .OrderBy(p => p.LessonTypeId)
            .ThenBy(p => p.ClassesIncluded)
            .Select(p => new PackageLineInput
            {
                PackageId = p.Id,
                LessonTypeId = p.LessonTypeId,
                LessonTypeName = p.LessonType?.Name ?? $"Type {p.LessonTypeId}",

                ClassesIncluded = p.ClassesIncluded,
                Weekly = p.Weekly,
                BaseValue = p.Valor,

                DisplayName = p.Name,
                Details = BuildDetails(p),

                Quantity = 0
            })
            .ToList();
    }

    private async Task HandleSubmit()
    {
        await OnSubmit.InvokeAsync(PackageLines);
    }

    private static string BuildDetails(Package p)
    {
        var duration = p.LessonType?.DurationInMinutes ?? 0;
        var weekly = p.Weekly ? "Weekly" : "Not weekly";

        return $"{p.ClassesIncluded} classes • {duration} min • {weekly}";
    }

    public class PackageLineInput
    {
        public int PackageId { get; set; }

        public string DisplayName { get; set; } = "";
        public string Details { get; set; } = "";

        public int LessonTypeId { get; set; }
        public string LessonTypeName { get; set; } = "";

        public int ClassesIncluded { get; set; }
        public bool Weekly { get; set; }

        public decimal BaseValue { get; set; }

        public int Quantity { get; set; }

        public decimal Total => BaseValue * Quantity;
    }
}