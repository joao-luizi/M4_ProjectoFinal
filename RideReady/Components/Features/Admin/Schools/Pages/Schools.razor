@page "/admin/schools"
@attribute [Authorize(Roles = "Administrator")]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using RepositoryLibrary.Features.Schools.Entities
@using RepositoryLibrary.Features.Schools.Interfaces
@inject ISchoolService SchoolService
@inject NavigationManager Nav
@inject DialogService DialogService

<RadzenCard Style="padding:1rem">

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween">
        <h3>Schools</h3>

        <RadzenButton Text="New School"
                      Icon="add"
                      Click="@CreateSchool" />
    </RadzenStack>

    <RadzenDataGrid TItem="School"
                    Data="@schools"
                    LoadData="@LoadData"
                    Count="@count"
                    AllowPaging="true"
                    PageSize="10"
                    AllowSorting="true">

        <Columns>

            <RadzenDataGridColumn TItem="School" Property="SchoolName" Title="Name" />
            <RadzenDataGridColumn TItem="School" Property="Email" Title="Email" />
            <RadzenDataGridColumn TItem="School" Property="Contact" Title="Contact" />
            <RadzenDataGridColumn TItem="School" Property="SchoolCapacity" Title="Capacity" />

            <RadzenDataGridColumn TItem="School" Title="Actions" Width="180px">
                <Template Context="school">

                    <RadzenButton Icon="edit"
                                  Size="ButtonSize.Small"
                                  Style="margin-right:5px"
                                  Click="@(() => EditSchool(school.SchoolId))" />

                    <RadzenButton Icon="visibility"
                                  Size="ButtonSize.Small"
                                  Style="margin-right:5px"
                                  Click="@(() => ViewSchool(school.SchoolId))" />

                    <RadzenButton Icon="delete"
                                  ButtonStyle="ButtonStyle.Danger"
                                  Size="ButtonSize.Small"
                                  Click="@(() => DeleteSchool(school.SchoolId))" />

                </Template>
            </RadzenDataGridColumn>

        </Columns>

    </RadzenDataGrid>

</RadzenCard>

@code {

    private List<School> schools = new();
    private int count;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        schools = await SchoolService.GetSchoolsAsync();
        count = schools.Count;
    }

    private void CreateSchool()
    {
        Nav.NavigateTo("/admin/schools/create");
    }

    private void EditSchool(int id)
    {
        Nav.NavigateTo($"/admin/schools/{id}/edit");
    }

    private void ViewSchool(int id)
    {
        Nav.NavigateTo($"/admin/schools/{id}/view");
    }

    private async Task DeleteSchool(int id)
    {
        var confirm = await DialogService.Confirm(
            "Are you sure you want to delete this school?",
            "Delete School");

        if (confirm == true)
        {
            await SchoolService.DeleteSchoolByIdAsync(id);
            await LoadData();
        }
    }
}
