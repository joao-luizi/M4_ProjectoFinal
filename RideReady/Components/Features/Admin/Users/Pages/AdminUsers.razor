@page "/admin/users"
@attribute [Authorize(Roles = StaticRole.Admin)]
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using RepositoryLibrary.Features.Users.DTOs
@using RepositoryLibrary.Features.Users.Entities
@using RepositoryLibrary.Features.Users.Interfaces
@using RepositoryLibrary.Shared.Enums
@using RideReady.Components.Features.Admin.Users.Modals

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JSRuntime
@inject IStudentExportService _studentExportService
@inject IUserService _usersService
@inject NotificationService NotificationService;




<h1>User Management</h1>

@if (_loading)
{
    <p>Loading...</p>
}
else
{
     @if (showForm)
    {
        <UserForm User="editingUser"
                   Mode="formMode"
                   OnSave="SaveUser"
        OnCancel="CloseForm" />
    }
    else
    {
        
    <RadzenButton Text="Create" Click="@CreateUser" />
    <RadzenButton Text="Exportar alunos para Excel" Icon="download" ButtonStyle="ButtonStyle.Success" Click="@(args => ExportToExcel())" class="rz-mb-3 rz-ml-2" />
    <RadzenDataGrid Data="@users" TItem="AdminUserListItemDto"
                    AllowPaging="true"
                    AllowSorting="true"
                    PageSize="10">

        <Columns>

            <RadzenDataGridColumn Title="User">
                <Template Context="user">
                    <img src="@(user.PhotoPath ?? "User_default_image/user.png")"
                         style="width:32px;height:32px;border-radius:4px;margin-right:8px;" />
                    @user.FullName
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn Property="Email" Title="Email" />

            <RadzenDataGridColumn Property="PhoneNumber" Title="Phone" />

            <RadzenDataGridColumn Property="Role" Title="Role" />

            <RadzenDataGridColumn Title="State">
                <Template Context="user">
                    <span style="@(user.IsActive ? "color:green;font-weight:bold" : "color:red;font-weight:bold")">
                        @(user.IsActive ? "Active" : "Inactive")
                    </span>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn Title="Actions">
                <Template Context="user">

                    <RadzenButton Icon="visibility" Click="@(() => ViewUser(user))" />
                    <RadzenButton Icon="edit" Click="@(() => EditUser(user))" />
                </Template>
            </RadzenDataGridColumn>

        </Columns>
    </RadzenDataGrid>
    }
}

@code {


    private AdminUserDetailsDto? editingUser;
    private bool showForm;
    private List<AdminUserListItemDto> users = [];
    private bool _loading = true;
    private ModalFormMode formMode { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var data = await _usersService.GetAdminUsersAsync();

        users = data.Users;
        _loading = false;
    }

    private async Task ToggleUser(AdminUserListItemDto user)
    {
        if (user.IsActive)
            await _usersService.DeactivateUserAsync(user.Id);
        else
            await _usersService.ActivateUserAsync(user.Id);

        await Reload();
    }

    private async Task Reload()
    {
        var data = await _usersService.GetAdminUsersAsync();
        users = data.Users;
    }

    private async Task<int> GetSchoolIdAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        return Convert.ToInt32(authState.User.FindFirst("SchoolId")?.Value);
    }

    private async Task ExportToExcel()
    {
        try
        {
            int schoolId = await GetSchoolIdAsync();
            byte[] fileBytes = await _studentExportService.ExportStudentsToExcelAsync(schoolId);
            string base64 = Convert.ToBase64String(fileBytes);
            await JSRuntime.InvokeVoidAsync("downloadFileFromBytes", "Alunos.xlsx", base64);
        }
        catch (Exception)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erro", "Falha ao exportar os alunos.");
        }
    }

    private async Task ViewUser(AdminUserListItemDto user)
    {
        editingUser = await _usersService.GetUserDetailsAsync(user.Id);
        formMode = ModalFormMode.View;
        showForm = true;
    }

    private async Task SaveUser(AdminUserDetailsDto user)
    {
        try
        {
            await _usersService.SaveUserAsync(user);

            await Reload();

            showForm = false;
            editingUser = null;

            NotificationService.Notify(
                NotificationSeverity.Success,
                "Success",
                "User saved successfully"
            );
        }
        catch (Exception ex)
        {
            NotificationService.Notify(
                NotificationSeverity.Error,
                "Error",
                "Failed to save user"
            );
        }
    }

    private async Task EditUser(AdminUserListItemDto user)
    {
        editingUser = await _usersService.GetUserDetailsAsync(user.Id);
        formMode = ModalFormMode.Edit;
        showForm = true;
    }

    private void CreateUser()
    {
        editingUser = new AdminUserDetailsDto();
        formMode = ModalFormMode.Create;
        showForm = true;

    }

    private void CloseForm()
    {
        showForm = false;
        editingUser = null;
        formMode = ModalFormMode.None;
    }
}