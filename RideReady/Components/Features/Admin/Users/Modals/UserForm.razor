@using Microsoft.AspNetCore.Components.Forms
@using RepositoryLibrary.Features.Users.DTOs
@using RepositoryLibrary.Features.Users.Entities
@using RepositoryLibrary.Shared.Enums
@using Radzen
@using Radzen.Blazor

@if (User is null)
{
    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
}
else
{
    <RadzenTemplateForm TItem="AdminUserDetailsDto"
                        Data="@User"
                        Submit="@Save">

        <RadzenCard>

            <!-- FOTO -->
            <RadzenStack Orientation="Orientation.Horizontal"
                         Gap="20px"
                         AlignItems="AlignItems.Center"
                         class="mb-4">

                <img src="@(PreviewImage ?? User.PhotoPath ?? "User_default_image/user.png")"
                     style="width:120px;height:120px;border-radius:12px;object-fit:cover;border:1px solid #ddd;" />

                @if (Mode != ModalFormMode.View)
                {
                    <InputFile OnChange="HandleImageSelected" />
                }

            </RadzenStack>

            <RadzenRow Gap="20px">

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="First Name" Style="width:100%;">
                        <RadzenTextBox @bind-Value="User.FirstName"
                                       Name="FirstName"
                                       Style="width:100%;"
                                       Disabled="@IsView" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Last Name" Style="width:100%;">
                        <RadzenTextBox @bind-Value="User.LastName"
                                       Name="LastName"
                                       Style="width:100%;"
                                       Disabled="@IsView" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Email" Style="width:100%;">
                        <RadzenTextBox @bind-Value="User.Email"
                                       Style="width:100%;"
                                       Disabled="@(!IsCreate)" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Phone" Style="width:100%;">
                        <RadzenTextBox @bind-Value="User.PhoneNumber"
                                       Style="width:100%;"
                                       Disabled="@IsView" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12">
                    <RadzenFormField Text="Address" Style="width:100%;">
                        <RadzenTextBox @bind-Value="User.Address"
                                       Style="width:100%;"
                                       Disabled="@IsView" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Birthdate" Style="width:100%;">
                        <RadzenDatePicker @bind-Value="User.Birthdate"
                                          DateFormat="dd/MM/yyyy"
                                          Style="width:100%;"
                                          Disabled="@IsView" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Role" Style="width:100%;">
                        <RadzenDropDown Data="@Roles"
                                        @bind-Value="User.Role"
                                        Style="width:100%;"
                                        Disabled="@IsView" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12">
                    <RadzenCheckBox @bind-Value="User.IsActive"
                                    Disabled="@IsView" />
                    <RadzenLabel Text="Active" class="ms-2" />
                </RadzenColumn>
                @if (IsCreate)
                {
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenFormField Text="Password" Style="width:100%;">
                            <RadzenPassword @bind-Value="User.Password"
                                            Style="width:100%;" />
                        </RadzenFormField>
                    </RadzenColumn>
                }

            </RadzenRow>

            <RadzenStack Orientation="Orientation.Horizontal"
                         Gap="10px"
                         JustifyContent="JustifyContent.End"
                         class="mt-4">

                @if (Mode != ModalFormMode.View)
                {
                    <RadzenButton Text="Save"
                                  Icon="save"
                                  ButtonType="ButtonType.Submit" />
                }

                <RadzenButton Text="Cancel"
                              Icon="close"
                              ButtonStyle="ButtonStyle.Light"
                              Click="OnCancelClicked" />

            </RadzenStack>

        </RadzenCard>

    </RadzenTemplateForm>
}

@code {
    [Parameter] public AdminUserDetailsDto? User { get; set; }

    [Parameter] public EventCallback<AdminUserDetailsDto> OnSave { get; set; }

    private string? PreviewImage;

    [Parameter] public ModalFormMode Mode { get; set; }


    [Parameter] public EventCallback OnCancel { get; set; }

    private bool IsView => Mode == ModalFormMode.View;
    private bool IsCreate => Mode == ModalFormMode.Create;
    private bool IsEdit => Mode == ModalFormMode.Edit;

    private List<string> Roles = new()
    {
        StaticRole.Admin,
        StaticRole.Teacher,
        StaticRole.Student
    };


    private async Task HandleImageSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;

        if (file is null)
            return;

        User!.NewPhoto = file;

        await using var stream = file.OpenReadStream(5 * 1024 * 1024);
        using var memoryStream = new MemoryStream();

        await stream.CopyToAsync(memoryStream);

        var bytes = memoryStream.ToArray();

        PreviewImage =
            $"data:{file.ContentType};base64,{Convert.ToBase64String(bytes)}";
    }


    private async Task Save()
    {
        if (User is null)
            return;

        await OnSave.InvokeAsync(User);
    }

    private async Task OnCancelClicked()
    {
        await OnCancel.InvokeAsync();
    }
}
