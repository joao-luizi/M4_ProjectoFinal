@using System.Globalization
@using RepositoryLibrary.Features.DashBoard.DTOs
@using RepositoryLibrary.Features.DashBoard.Interfaces
@using RideReady.Components.Shared
@inject IStudentDashboardService DashboardService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

@if (_loading)
{
    @* ---------- skeletons de carregamento ---------- *@
    <div class="dash-hero dash-skel"></div>
    <div class="dash-skel dash-skel-banner"></div>
    <div class="dash-stats">
        <div class="dash-skel dash-skel-stat"></div>
        <div class="dash-skel dash-skel-stat"></div>
        <div class="dash-skel dash-skel-stat"></div>
        <div class="dash-skel dash-skel-stat"></div>
    </div>
    <div class="dash-skel dash-skel-block"></div>
}
else
{
    @* ---------- faixa-manchete: foto + saudação + data, com vidro ---------- *@
    <div class="dash-hero">
        <img class="dash-hero-img" src="/Images/Cavalo_4.jpg" alt="" />
        <div class="dash-hero-overlay"></div>
        <div class="dash-hero-glass">
            <span class="dash-eyebrow">A minha área · Demonstração</span>
            <h2>@Greeting, Cavaleir@@.</h2>
            <p>@TodayLabel · As tuas aulas e a tua conta.</p>
        </div>
    </div>

    @* ---------- faixa de demonstração ---------- *@
    <div class="dash-demo-banner">
        <RadzenIcon Icon="science" />
        <div>
            <strong>Modo de demonstração</strong> — os números e gráficos neste painel
            são dados fictícios que ilustram as estatísticas que a aplicação
            consegue produzir a partir dos seus serviços e dados reais.
        </div>
    </div>

    @* ---------- manchete: a tua próxima aula ---------- *@
    @if (_nextLesson is not null)
    {
        <div class="dash-next">
            <div class="dash-next-when">
                <span class="dash-next-label">Próxima aula</span>
                <span class="dash-next-date">@_nextLesson.Date.ToString("dd/MM")</span>
                <span class="dash-next-time">@_nextLesson.Date.ToString("HH:mm")</span>
            </div>
            <div class="dash-next-info">
                <span class="dash-next-type">@_nextLesson.Type</span>
                <div class="dash-next-chips">
                    <span class="dash-chip">@_nextLesson.Teacher</span>
                    <span class="dash-chip dash-chip-tan">@_nextLesson.Horse</span>
                </div>
            </div>
        </div>
    }
    else
    {
        <EmptyState Title="Sem aulas marcadas"
                    Text="Quando marcares uma aula, ela aparece aqui em destaque." />
    }

    @* ---------- cartão de dívida (só aparece se houver valor em falta) ---------- *@
    @if (_outstandingAmount > 0)
    {
        <div class="dash-debt">
            <RadzenIcon Icon="error" />
            <div class="dash-debt-text">
                <strong>Pagamento pendente: @_outstandingAmount.ToString("C", new CultureInfo("pt-PT"))</strong>
                <span>Regulariza até @_nextDueDate.ToString("dd/MM/yyyy") para continuares a marcar aulas.</span>
            </div>
        </div>
    }

    @* ---------- StatCards ---------- *@
    <div class="dash-stats">
        <StatCard Label="Aulas Agendadas" Value="@_scheduledClasses.ToString()"
                  Caption="@NextClassCaption" Icon="event" Accent="blue"
                  CountUp="true" />
        <StatCard Label="Créditos" Value="@_totalCredits.ToString()"
                  Caption="Saldo atual de aulas" Icon="confirmation_number" Accent="amber"
                  CountUp="true" />
        <StatCard Label="Subscrições Ativas" Value="@_activeSubscriptions.ToString()"
                  Caption="Plano atual" Icon="autorenew" Accent="navy"
                  CountUp="true" />
        <StatCard Label="Horário Escolar" Value="8:00–19:00"
                  Caption="Segunda a Sábado" Icon="schedule" Accent="tan" />
    </div>

    @* ---------- estatísticas ---------- *@
    <h3 class="dash-h3">As tuas estatísticas</h3>
    <p class="dash-demo-note">Dados de demonstração</p>

    <RadzenRow class="rz-mb-4" Gap="1rem">
        <RadzenColumn Width="50%">
            <div class="dash-card">
                <RadzenText Text="Créditos por produto" class="dash-card-title" />
                <RadzenChart Style="height: 260px;">
                    <RadzenDonutSeries Data="@_creditsByProduct" CategoryProperty="Product"
                                       ValueProperty="Credits"
                                       Fills="@(new[] { "#3f7fae", "#d9a531", "#b98a52" })" />
                    <RadzenLegend Position="LegendPosition.Right" />
                </RadzenChart>
            </div>
        </RadzenColumn>

        <RadzenColumn Width="50%">
            <div class="dash-card">
                <RadzenText Text="As tuas aulas por mês" class="dash-card-title" />
                <RadzenChart Style="height: 260px;">
                    <RadzenColumnSeries Data="@_monthlyLessons" CategoryProperty="Month"
                                        ValueProperty="Lessons" Title="Aulas" Fill="#3f7fae" />
                    <RadzenColumnOptions Radius="8" />
                    <RadzenValueAxis>
                        <RadzenGridLines Visible="true" />
                    </RadzenValueAxis>
                    <RadzenLegend Visible="false" />
                </RadzenChart>
            </div>
        </RadzenColumn>
    </RadzenRow>

    @* ---------- timeline de próximas aulas ---------- *@
    <h3 class="dash-h3">Próximas aulas</h3>
    @if (_upcoming.Any())
    {
        <div class="dash-timeline">
            @foreach (var lesson in _upcoming)
            {
                <div class="dash-tl-row">
                    <div class="dash-tl-marker">
                        <span class="dash-tl-dot"></span>
                        <span class="dash-tl-line"></span>
                    </div>
                    <div class="dash-tl-when">
                        <span class="dash-tl-date">@lesson.Date.ToString("dd/MM")</span>
                        <span class="dash-tl-time">@lesson.Date.ToString("HH:mm")</span>
                    </div>
                    <div class="dash-tl-info">
                        <span class="dash-tl-type">@lesson.Type</span>
                        <span class="dash-tl-detail">@lesson.Teacher · @lesson.Horse</span>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <EmptyState Title="Sem aulas no horizonte"
                    Text="As tuas próximas aulas marcadas aparecem nesta linha do tempo." />
    }
}

