@page "/dashboard"
@rendermode InteractiveServer
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using RideReady.Components.Features.Dashboard.Components
@using RideReady.Services

@inject AuthenticationStateProvider AuthStateProvider
@inject IToastService Toast
@inject NavigationManager Nav

@if (_loading)
{
    <p>Loading dashboard...</p>
}
else
{
    @switch (_userRole)
    {
        case "Administrator":
            <AdminDashboard />
            break;

        case "Teacher":
            <TeacherDashboard />
            break;

        case "Student":
            <StudentDashboard />
            break;

        default:
            <p>Role not recognized</p>
            break;
    }
}

@code {
    private string? _userRole;
    private string _firstName = "";
    private bool _loading = true;

    /// <summary>Vem de /dashboard?welcome=1 (posto pelo Login após sucesso).</summary>
    [SupplyParameterFromQuery(Name = "welcome")]
    public string? Welcome { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        _userRole = user.FindFirst(ClaimTypes.Role)?.Value;
        _firstName = user.FindFirst("FirstName")?.Value ?? "";
        _loading = false;
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        // Toast de boas-vindas: só na chegada vinda do login (welcome=1),
        // disparado depois do render (o NotificationService precisa do
        // circuito interativo vivo). Limpamos o query param a seguir,
        // para um F5 não repetir o toast.
        if (firstRender && Welcome == "1")
        {
            var greeting = string.IsNullOrEmpty(_firstName)
                ? "Sessão iniciada. Bem-vind@ de volta!"
                : $"Sessão iniciada. Bem-vind@ de volta, {_firstName}!";
            Toast.ShowSuccess(greeting);
            Nav.NavigateTo("/dashboard", replace: true);
        }
        return Task.CompletedTask;
    }
}
