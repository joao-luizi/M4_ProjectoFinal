@page "/401"

@using RideReady.Components.Layout

@layout EmptyLayout

<PageTitle>401 — RideReady</PageTitle>

<section class="px">

    <a class="px-brand" href="/">
        <img src="/favicon.png" alt="" />
        <span>RideReady</span>
    </a>

    <div class="px-cloud px-cloud-1"><svg viewBox="0 0 56 20" shape-rendering="crispEdges" aria-hidden="true"><g><rect x="16" y="0" width="16" height="4"/><rect x="36" y="4" width="12" height="4"/><rect x="8" y="4" width="24" height="4"/><rect x="4" y="8" width="48" height="8"/><rect x="12" y="16" width="32" height="4"/></g></svg></div>
    <div class="px-cloud px-cloud-2"><svg viewBox="0 0 56 20" shape-rendering="crispEdges" aria-hidden="true"><g><rect x="16" y="0" width="16" height="4"/><rect x="36" y="4" width="12" height="4"/><rect x="8" y="4" width="24" height="4"/><rect x="4" y="8" width="48" height="8"/><rect x="12" y="16" width="32" height="4"/></g></svg></div>

    <div class="px-card">
        <div class="px-code">401</div>
        <h1>Não autorizado</h1>
        <p>Precisas de iniciar sessão para entrar aqui.</p>
        <a href="/Account/Login" class="px-btn">Iniciar sessão</a>
        <a href="/" class="px-btn px-btn-ghost">Voltar ao início</a>
    </div>

    @* a cena: pónei-segurança de óculos escuros, atrás da corda *@
