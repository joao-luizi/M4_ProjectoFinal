@page "/Account/RegisterConfirmation"

@using Microsoft.AspNetCore.Identity
@using RepositoryLibrary.Features.Users.Entities
@using RideReady.Components.Layout

@inject UserManager<EMUser> UserManager
@inject IdentityRedirectManager RedirectManager

@layout EmptyLayout

<PageTitle>Conta criada — RideReady</PageTitle>

<section class="rc">

    <a class="rc-brand" href="/">
        <img src="/favicon.png" alt="" />
        <span>RideReady</span>
    </a>

    <div class="rc-card">
        <h1>Bem-vind@@ ao RideReady!</h1>

        <StatusMessage Message="@statusMessage" />

        @if (statusMessage is null)
        {
            <div class="alert alert-success" role="alert">
                A tua conta foi criada com sucesso.
            </div>
            <p>
                Enviámos-te um email de confirmação@(Email is null ? "" : $" para {Email}").
                Clica no link desse email para ativares a conta antes de entrares.
            </p>
        }

        <div class="mt-3">
            <a href="Account/Login" class="rc-btn">Continuar para o login</a>
        </div>
    </div>

    @* nuvens pixel a derivar *@
    <div class="rc-cloud rc-cloud-1"><svg viewBox="0 0 56 20" shape-rendering="crispEdges" aria-hidden="true"><g><rect x="16" y="0" width="16" height="4"/><rect x="36" y="4" width="12" height="4"/><rect x="8" y="4" width="24" height="4"/><rect x="4" y="8" width="48" height="8"/><rect x="12" y="16" width="32" height="4"/></g></svg></div>
    <div class="rc-cloud rc-cloud-2"><svg viewBox="0 0 56 20" shape-rendering="crispEdges" aria-hidden="true"><g><rect x="16" y="0" width="16" height="4"/><rect x="36" y="4" width="12" height="4"/><rect x="8" y="4" width="24" height="4"/><rect x="4" y="8" width="48" height="8"/><rect x="12" y="16" width="32" height="4"/></g></svg></div>
    <div class="rc-cloud rc-cloud-3"><svg viewBox="0 0 56 20" shape-rendering="crispEdges" aria-hidden="true"><g><rect x="16" y="0" width="16" height="4"/><rect x="36" y="4" width="12" height="4"/><rect x="8" y="4" width="24" height="4"/><rect x="4" y="8" width="48" height="8"/><rect x="12" y="16" width="32" height="4"/></g></svg></div>
    <div class="rc-cloud rc-cloud-4"><svg viewBox="0 0 56 20" shape-rendering="crispEdges" aria-hidden="true"><g><rect x="16" y="0" width="16" height="4"/><rect x="36" y="4" width="12" height="4"/><rect x="8" y="4" width="24" height="4"/><rect x="4" y="8" width="48" height="8"/><rect x="12" y="16" width="32" height="4"/></g></svg></div>

    @* o pónei levanta voo — uma vez, ao carregar *@
    <div class="rc-peg">
        <svg class="rc-horse" viewBox="0 0 112 60" shape-rendering="crispEdges" aria-hidden="true"><g class="hwingU"><rect x="28" y="0" width="12" height="4"/><rect x="24" y="4" width="20" height="4"/><rect x="28" y="8" width="12" height="4"/><rect x="32" y="12" width="4" height="4"/></g><g class="hwingD"><rect x="32" y="20" width="8" height="4"/><rect x="28" y="24" width="16" height="4"/><rect x="32" y="28" width="8" height="4"/></g><g class="hbody"><rect x="72" y="0" width="8" height="4"/><rect x="64" y="4" width="16" height="4"/><rect x="60" y="8" width="24" height="4"/><rect x="60" y="12" width="12" height="4"/><rect x="76" y="12" width="12" height="4"/><rect x="60" y="16" width="32" height="4"/><rect x="60" y="20" width="20" height="4"/><rect x="12" y="24" width="8" height="4"/><rect x="48" y="24" width="28" height="4"/><rect x="16" y="28" width="16" height="4"/><rect x="40" y="28" width="40" height="4"/><rect x="12" y="32" width="72" height="4"/><rect x="8" y="36" width="80" height="4"/><rect x="8" y="40" width="80" height="4"/><rect x="8" y="44" width="76" height="4"/><rect x="12" y="48" width="68" height="4"/><g class="legB"><rect x="24" y="52" width="8" height="4"/><rect x="52" y="52" width="8" height="4"/><rect x="24" y="56" width="8" height="4"/><rect x="52" y="56" width="8" height="4"/></g></g><g class="hmane"><rect x="60" y="0" width="8" height="4"/><rect x="56" y="4" width="8" height="4"/><rect x="4" y="8" width="8" height="4"/><rect x="56" y="8" width="4" height="4"/><rect x="4" y="12" width="12" height="4"/><rect x="56" y="12" width="4" height="4"/><rect x="8" y="16" width="8" height="4"/><rect x="56" y="16" width="4" height="4"/><rect x="12" y="20" width="4" height="4"/><rect x="56" y="20" width="4" height="4"/></g><g class="heye"><rect x="72" y="12" width="4" height="4"/></g></svg>
    </div>

    <div class="rc-ground"></div>

</section>

@code {
    private string? statusMessage;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? Email { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (Email is null)
        {
            RedirectManager.RedirectTo("");
            return;
        }

        var user = await UserManager.FindByEmailAsync(Email);
        if (user is null)
        {
            HttpContext.Response.StatusCode = StatusCodes.Status404NotFound;
            statusMessage = "Não foi encontrada nenhuma conta para esse email.";
        }
    }
}
