@using System.Globalization
@using Radzen
@using RepositoryLibrary.Features.Email.DTOs
@using RepositoryLibrary.Features.Lessons.DTOs
@using RepositoryLibrary.Features.Lessons.Interfaces
@using RepositoryLibrary.Shared.Enums
@using RideReady.Components.Features.Lessons.Modals
@using RideReady.Components.Shared
@rendermode InteractiveServer
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject ILessonService LessonService

@if (Day is null)
{
    <RadzenCard>
        <p>Seleciona um dia para ver o detalhe</p>
    </RadzenCard>
}
else
{
    <RadzenCard class="rz-p-3 day-panel">

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween">

            <h4 class="day-title">@DayLabel</h4>

            <RadzenButton Text="Fechar"
                          ButtonStyle="ButtonStyle.Secondary"
                          Click="@OnClose" />
        </RadzenStack>
        <RadzenButton Text="Criar aula"
                      Icon="add_circle"
                      class="day-create"
                      Click="CreateLesson" />


        @if (!Day.Lessons.Any())
        {
            <EmptyState Title="Dia sem aulas"
                        Text="Cria a primeira aula deste dia com o botão acima." />
        }

        @foreach (var (lesson, idx) in Day.Lessons.Select((l, i) => (l, i)))
        {
            <RadzenCard class="rz-mb-2 day-lesson" Style="@($"animation-delay: {idx * 60}ms")">

                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween">

                    <div>
                        <b class="day-lesson-type">@lesson.LessonType</b><br />
                        @lesson.Begin.ToString("HH:mm") - @lesson.End.ToString("HH:mm")<br />
                        <span class="day-lesson-school">@lesson.SchoolName</span>
                    </div>

                    <div class="day-occ">
                        <span class="day-occ-label">Inscritos</span>
                        <span class="day-occ-value">@lesson.BookedSpots / @lesson.MaxSpots</span>
                    </div>

                    <div class="day-occ">
                        <span class="day-occ-label">Livres</span>
                        <span class="day-occ-value @(lesson.FreeSpots == 0 ? "day-occ-full" : "")">@lesson.FreeSpots</span>
                    </div>

                </RadzenStack>

                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" class="rz-mt-2">

                    <RadzenButton Text="Editar"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Click="@(() => EditLesson(lesson))" />
                    <RadzenButton Text="Presenças"
                                  ButtonStyle="ButtonStyle.Warning"
                                  Click="@(() => OpenAttendance(lesson))" />
                    <RadzenButton Text="Eliminar"
                                  ButtonStyle="ButtonStyle.Danger"
                                  Click="@(() => DeleteLesson(lesson))" />


                </RadzenStack>

            </RadzenCard>
        }

    </RadzenCard>
}

@code {

    [Parameter]
    public DayScheduleDto? Day { get; set; }

    [Parameter]
    public string? SchoolName { get; set; }

    [Parameter]
    public int? SchoolId { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback OnLessonChanged { get; set; }

    /// <summary>Data do dia por extenso, em PT (ex.: "Segunda-feira, 1 de junho").</summary>
    private string DayLabel
    {
        get
        {
            var pt = new CultureInfo("pt-PT");
            var label = Day!.Date.ToString("dddd, d 'de' MMMM", pt);
            return char.ToUpper(label[0]) + label[1..];
        }
    }

    private async Task CallDialog(ModalFormMode mode, string title, int lessonId)
    {
        var result = await DialogService.OpenAsync<LessonForm>(
            title,
            new Dictionary<string, object>
            {
                ["Mode"] = mode,
                ["Date"] = Day.Date,
                ["SchoolName"] = SchoolName ?? "",
                ["SchoolId"] = SchoolId ?? 0,
                ["LessonId"] = lessonId
            },
            new DialogOptions
            {
                Width = "1000px",
                Height = "auto",
                Resizable = true,
                Draggable = true
            });

        if (result is bool success && success)
        {
            string message = "";
            if (mode == ModalFormMode.Create)
                message = "Aula criada com sucesso";
            if (mode == ModalFormMode.Edit)
                message = "Aula atualizada com sucesso";
            NotificationService.Notify(
               NotificationSeverity.Success,
               "Sucesso",
               message);
            await OnLessonChanged.InvokeAsync();
        }
    }

    private async Task CreateLesson()
    {
        await CallDialog(ModalFormMode.Create, "Criar aula", 0);
    }

    private async Task EditLesson(LessonCalendarDto lesson)
    {
        await CallDialog(ModalFormMode.Edit, "Editar aula", lesson.LessonId);
    }

    private async Task ViewLesson(LessonCalendarDto lesson)
    {
        await CallDialog(ModalFormMode.View, "Ver aula", lesson.LessonId);
    }
    private async Task DeleteLesson(LessonCalendarDto lesson)
    {
        bool? confirm = await DialogService.Confirm(
            "Eliminar esta aula?",
            "Confirmar",
            new ConfirmOptions
            {
                OkButtonText = "Sim",
                CancelButtonText = "Não"
            });

        if (confirm != true)
            return;

        try
        {
            var userIdsForEmails = await LessonService.DeleteAsync(lesson.LessonId);

            var emailDto = new EmailSenderDto
            {
                UserIds = userIdsForEmails,
                Subject = "Aula cancelada",
                Body = $"A aula de {lesson.Begin:dd/MM HH:mm} foi cancelada."
            };

            //await EmailService.SendAsync(emailDto);

            NotificationService.Notify(
                NotificationSeverity.Success,
                "Eliminada",
                $"Aula eliminada. Alunos a notificar: {userIdsForEmails.Count}");

            await OnLessonChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(
                NotificationSeverity.Error,
                "Erro",
                ex.Message);
        }
    }

    private async Task OpenAttendance(LessonCalendarDto lesson)
    {
        var result = await DialogService.OpenAsync<AttendanceForm>(
            "Presenças da aula",
            new Dictionary<string, object>
            {
                ["LessonId"] = lesson.LessonId
            },
            new DialogOptions
            {
                Width = "900px",
                Height = "600px",
                Resizable = true,
                Draggable = true
            });

        if (result is bool success && success)
        {
            NotificationService.Notify(
                NotificationSeverity.Success,
                "Guardado",
                "Presenças atualizadas com sucesso");

            await OnLessonChanged.InvokeAsync();
        }
    }


}
