@using Radzen
@using RepositoryLibrary.Features.Email.DTOs
@using RepositoryLibrary.Features.Entitlements.DTOs
@using RepositoryLibrary.Features.Entitlements.Enums
@using RepositoryLibrary.Features.Lessons.DTOs
@using RepositoryLibrary.Features.Lessons.Interfaces
@using RepositoryLibrary.Shared.Enums
@using RideReady.Components.Features.Lessons.Modals
@rendermode InteractiveServer
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject ILessonService LessonService

@if (Day is null)
{
    <RadzenCard>
        <p>Select a day to see details</p>
    </RadzenCard>
}
else
{
    <RadzenCard class="rz-p-3">

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween">

            <h4>
                @Day.Date.DayOfWeek - @Day.Date.ToString("yyyy-MM-dd")
            </h4>

            <RadzenButton Text="Close"
                          ButtonStyle="ButtonStyle.Secondary"
                          Click="@OnClose" />
        </RadzenStack>
        <RadzenButton Text="Create Lesson"
                      Icon="add_circle"
                      Click="CreateLesson" />
       

        @foreach (var lesson in Day.Lessons)
        {
            <RadzenCard class="rz-mb-2">

                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween">

                    <div>
                        <b>@lesson.LessonType</b><br />
                        @lesson.Begin.ToString("HH:mm") - @lesson.End.ToString("HH:mm")<br />
                        @lesson.SchoolName
                    </div>

                    <div>
                        @lesson.BookedSpots / @lesson.MaxSpots
                    </div>

                    <div>
                        Free: @lesson.FreeSpots
                    </div>

                </RadzenStack>

                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" class="rz-mt-2">

                    <RadzenButton Text="Edit"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Click="@(() => EditLesson(lesson))" />
                    <RadzenButton Text="Attendance"
                                  ButtonStyle="ButtonStyle.Warning"
                                  Click="@(() => OpenAttendance(lesson))" />
                    <RadzenButton Text="Delete"
                                  ButtonStyle="ButtonStyle.Danger"
                                  Click="@(() => DeleteLesson(lesson))" />


                </RadzenStack>

            </RadzenCard>
        }

    </RadzenCard>
}

@code {

    [Parameter]
    public DayScheduleDto? Day { get; set; }

    [Parameter]
    public string? SchoolName { get; set; }

    [Parameter]
    public int? SchoolId { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback OnLessonChanged { get; set; }

    private async Task CallDialog(ModalFormMode mode, string title, int lessonId)
    {
        var result = await DialogService.OpenAsync<LessonForm>(
            title,
            new Dictionary<string, object>
            {
                ["Mode"] = mode,
                ["Date"] = Day.Date,
                ["SchoolName"] = SchoolName ?? "",
                ["SchoolId"] = SchoolId ?? 0,
                ["LessonId"] = lessonId
            },
            new DialogOptions
            {
                Width = "1000px",
                Height = "auto",
                Resizable = true,
                Draggable = true
            });

        if (result is bool success && success)
        {
            string message = "";
            if (mode == ModalFormMode.Create)
                message = "Lesson created successfully";
            if (mode == ModalFormMode.Edit)
                message = "Lesson updated successfully";
            NotificationService.Notify(
               NotificationSeverity.Success,
               "Success",
               message);
            await OnLessonChanged.InvokeAsync();
        }
    }

    private async Task CreateLesson()
    {
        await CallDialog(ModalFormMode.Create, "Create Lesson", 0);
    }

    private async Task EditLesson(LessonCalendarDto lesson)
    {
        await CallDialog(ModalFormMode.Edit, "Edit Lesson", lesson.LessonId);
    }

    private async Task ViewLesson(LessonCalendarDto lesson)
    {
        await CallDialog(ModalFormMode.View, "View Lesson", lesson.LessonId);
    }
    private async Task DeleteLesson(LessonCalendarDto lesson)
    {
        bool? confirm = await DialogService.Confirm(
            "Delete this lesson?",
            "Confirm",
            new ConfirmOptions
            {
                OkButtonText = "Yes",
                CancelButtonText = "No"
            });

        if (confirm != true)
            return;

        try
        {
            var userIdsForEmails = await LessonService.DeleteAsync(lesson.LessonId);

            var emailDto = new EmailSenderDto
            {
                UserIds = userIdsForEmails,
                Subject = "Lesson cancelled",
                Body = $"The lesson on {lesson.Begin:dd/MM HH:mm} has been cancelled."
            };

            //await EmailService.SendAsync(emailDto);

            NotificationService.Notify(
                NotificationSeverity.Success,
                "Deleted",
                $"Lesson deleted and users notified  Count: {userIdsForEmails.Count}");

            await OnLessonChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(
                NotificationSeverity.Error,
                "Error",
                ex.Message);
        }
    }
    private static string BuildErrorMessage(
    IEnumerable<BookingValidationError> errors)
    {
        return string.Join(
            Environment.NewLine,
            errors.Select(error => error switch
            {
                BookingValidationError.AlreadyBooked =>
                    "You are already enrolled in this lesson.",

                BookingValidationError.NoActiveSubscription =>
                    "You do not have an active subscription for this lesson type.",

                BookingValidationError.SubscriptionExpired =>
                    "Your subscription is not currently valid.",

                BookingValidationError.NoCreditsAvailable =>
                    "You do not have enough credits for this lesson type.",

                BookingValidationError.LessonNotFound =>
                    "The lesson could not be found.",

                _ => "An unknown error occurred."
            }));
    }
    private async Task OpenAttendance(LessonCalendarDto lesson)
    {
        var result = await DialogService.OpenAsync<AttendanceForm>(
            "Lesson Attendance",
            new Dictionary<string, object>
            {
                ["LessonId"] = lesson.LessonId
            },
            new DialogOptions
            {
                Width = "900px",
                Height = "600px",
                Resizable = true,
                Draggable = true
            });

        if (result is BookingResult bookingResult)
        {
            if (bookingResult.Success)
            {
                NotificationService.Notify(
                    NotificationSeverity.Success,
                    "Success",
                    "You have been enrolled in the lesson.");
            }
            else
            {
                NotificationService.Notify(
                    NotificationSeverity.Error,
                    "Unable to enroll",
                    BuildErrorMessage(bookingResult.Errors));
            }
        }
    }
   

}
