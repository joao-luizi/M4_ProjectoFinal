@page "/lessons"
@rendermode InteractiveServer

@using System.Globalization
@using Radzen
@using RepositoryLibrary.Features.Lessons.DTOs
@using RepositoryLibrary.Features.Lessons.Interfaces
@using RepositoryLibrary.Features.Schools.DTOs
@using RepositoryLibrary.Features.Schools.Interfaces
@using RideReady.Components.Features.Lessons.Components
@inject ILessonScheduleService LessonScheduleService
@inject ISchoolService SchoolService

<RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" class="rz-p-3 rr-cal-filters">

    <RadzenStack Orientation="Orientation.Vertical" Gap="0.2rem">
        <RadzenLabel Text="Ano" />
        <RadzenNumeric @bind-Value="year" Change="@((int _) => OnScopeChanged())" />
    </RadzenStack>

    <RadzenStack Orientation="Orientation.Vertical" Gap="0.2rem">
        <RadzenLabel Text="Mês" />
        <RadzenDropDown @bind-Value="month"
                        Data="@months"
                        TextProperty="Name"
                        ValueProperty="Number"
                        Change="@OnScopeChanged" />


    </RadzenStack>

    <RadzenStack Orientation="Orientation.Vertical" Gap="0.2rem">
        <RadzenLabel Text="Escola" />
        <RadzenDropDown Data="@schools"
                        TextProperty="SchoolName"
                        ValueProperty="SchoolId"
                        @bind-Value="selectedSchoolId"
                        Change="OnScopeChanged" />
    </RadzenStack>

</RadzenStack>

@if (calendarDays is not null)
{
    @if (selectedDay is not null)
    {
        <DayLessonsDetails Day="selectedDay"
                           SchoolId="@selectedSchoolId"
                           SchoolName="@schools.FirstOrDefault(x => x.SchoolId == selectedSchoolId)?.SchoolName"
                           OnClose="() => selectedDay = null"
                           OnLessonChanged="ReloadAfterLessonChange" />
    }
    else
    {
        <div class="rr-cal-weekhead">
            <span>Seg</span><span>Ter</span><span>Qua</span><span>Qui</span><span>Sex</span><span>Sáb</span><span>Dom</span>
        </div>

        <div class="rr-cal-grid">

            @for (int s = 0; s < LeadingBlanks; s++)
            {
                <div class="rr-cal-blank"></div>
            }

            @foreach (var (day, idx) in calendarDays.Select((d, i) => (d, i)))
            {
                <RadzenCard class="@DayCardClass(day)"
                            Style="@($"animation-delay: {idx * 18}ms")"
                            @onclick="() => SelectDay(day)">

                    <div class="rr-cal-head">
                        <span class="rr-cal-num">@day.Date.Day</span>
                        <span class="rr-cal-weekday">@WeekdayLabel(day.Date)</span>
                    </div>

                    @if (day.Lessons.Any())
                    {
                        <div class="rr-cal-lessons">
                            @day.Lessons.Count @(day.Lessons.Count == 1 ? "aula" : "aulas")
                        </div>
                        <div class="rr-cal-slots @(CalculateFreeSlots(day) == 0 ? "rr-cal-slots-full" : "")">
                            @(CalculateFreeSlots(day) == 0 ? "Lotado" : $"{CalculateFreeSlots(day)} vagas")
                        </div>
                    }
                    else
                    {
                        <div class="rr-cal-empty">Sem aulas</div>
                    }

                </RadzenCard>
            }

        </div>
    }
}



@code {

    int? selectedSchoolId;
    int year = 2026;
    int month = 6;

    private sealed record MonthOption(int Number, string Name);
    List<MonthOption> months = Enumerable.Range(1, 12)
        .Select(i =>
        {
            var name = new CultureInfo("pt-PT").DateTimeFormat.GetMonthName(i);
            return new MonthOption(i, char.ToUpper(name[0]) + name[1..]);
        })
        .ToList();

    MonthScheduleDto? schedule;
    List<DayScheduleDto>? calendarDays;
    DayScheduleDto? selectedDay;
    public List<SelectSchoolDto> schools;
    async Task OnScopeChanged()
    {
        await LoadCalendar();
    }

    protected override async Task OnInitializedAsync()
    {
        // FIX: escolher a escola ANTES de carregar o calendário.
        // (Antes, o primeiro load corria com selectedSchoolId = null
        // e pedia as aulas da "escola 0" — calendário vazio até se
        // mexer no dropdown.)
        schools = await SchoolService.GetSchoolsListAsync();
        selectedSchoolId = schools.FirstOrDefault()?.SchoolId;
        await LoadCalendar();
    }

    private async Task ReloadAfterLessonChange()
    {
        // FIX: guardar a data ANTES do reload (o LoadCalendar limpa o
        // selectedDay, por isso a restauração antiga nunca encontrava nada
        // e o painel do dia fechava-se após criar/editar uma aula).
        var date = selectedDay?.Date;

        await LoadCalendar();

        selectedDay = calendarDays?
            .FirstOrDefault(x => x.Date == date);
    }

    async Task LoadCalendar()
    {
        schools = await SchoolService.GetSchoolsListAsync();

        schedule = await LessonScheduleService
            .GetMonthlyScheduleAsync(year, month, selectedSchoolId ?? 0);

        BuildCalendar();
        selectedDay = null;
    }


    void BuildCalendar()
    {
        calendarDays = new List<DayScheduleDto>();

        var daysInMonth = DateTime.DaysInMonth(year, month);

        for (int i = 1; i <= daysInMonth; i++)
        {
            var date = new DateOnly(year, month, i);

            var existing = schedule?.Days
                .FirstOrDefault(d => d.Date == date);

            calendarDays.Add(existing ?? new DayScheduleDto
            {
                Date = date,
                Lessons = new List<LessonCalendarDto>()
            });
        }
    }

    void SelectDay(DayScheduleDto day)
    {
        selectedDay = day;
    }

    int CalculateFreeSlots(DayScheduleDto day)
    {
        if (day.Lessons == null || !day.Lessons.Any())
            return 0;

        int totalMax = day.Lessons.Sum(l => l.MaxSpots);
        int totalBooked = day.Lessons.Sum(l => l.BookedSpots);

        return totalMax - totalBooked;
    }

    /// <summary>Cartões vazios antes do dia 1, para alinhar com a coluna do dia da semana (semana a começar à segunda).</summary>
    int LeadingBlanks =>
        ((int)new DateOnly(year, month, 1).DayOfWeek + 6) % 7;

    /// <summary>Dia da semana abreviado em PT (Seg, Ter, ...).</summary>
    string WeekdayLabel(DateOnly date)
    {
        var pt = new CultureInfo("pt-PT");
        var label = date.ToString("ddd", pt).TrimEnd('.');
        return char.ToUpper(label[0]) + label[1..];
    }

    /// <summary>Classes do cartão do dia: com aulas / vazio / hoje.</summary>
    string DayCardClass(DayScheduleDto day)
    {
        var cls = "rr-cal-day";
        if (day.Lessons.Any()) cls += " rr-cal-day-busy";
        if (day.Date == DateOnly.FromDateTime(DateTime.Today)) cls += " rr-cal-day-today";
        return cls;
    }
}
