@using System.Security.Claims
@using RepositoryLibrary.Features.Lessons.DTOs
@using RepositoryLibrary.Features.Lessons.Interfaces
@using RepositoryLibrary.Features.Users.Entities
@using RideReady.Components.Shared
@inject ILessonService LessonService
@inject AuthenticationStateProvider AuthStateProvider
@inject DialogService DialogService

<RadzenStack Gap="1rem" class="att-panel">

    @* O título vive no cabeçalho do diálogo ("Presenças da aula") —
       o H5 que aqui estava duplicava-o. *@

    @if (!Model.Students.Any())
    {
        <EmptyState Title="Ainda sem inscritos"
                    Text="Quando os alunos marcarem esta aula, aparecem nesta lista." />
    }

    @foreach (var (row, idx) in Model.Students.Select((r, i) => (r, i)))
    {
        <RadzenCard class="rz-p-2 att-row" Style="@($"animation-delay: {idx * 50}ms")">

            <RadzenStack Orientation="Orientation.Horizontal"
                         JustifyContent="JustifyContent.SpaceBetween"
                         AlignItems="AlignItems.Center">

                <!-- NAME -->
                <div class="att-name">
                    <UserAvatar Name="@row.Name" Size="32" />
                    <b>@row.Name</b>
                </div>

                <!-- TEACHER / ADMIN -->
                @if (CanEditAttendance)
                {
                    <div class="att-check">
                        <RadzenCheckBox TValue="bool"
                                        @bind-Value="row.WasPresent" />
                        <span>Presente</span>
                    </div>
                }

                <!-- STUDENT ACTION -->


            </RadzenStack>

        </RadzenCard>
    }

    @if (IsStudent)
    {
        <RadzenCard class="rz-p-3 att-self">

            <RadzenStack Orientation="Orientation.Horizontal"
                         JustifyContent="JustifyContent.SpaceBetween"
                         AlignItems="AlignItems.Center">

                <div class="att-self-info">
                    <b>A tua inscrição</b>

                    @if (MyRow?.IsBooked == true)
                    {
                        <RadzenBadge BadgeStyle="BadgeStyle.Success">
                            Inscrição confirmada
                        </RadzenBadge>
                    }
                    else
                    {
                        <RadzenBadge BadgeStyle="BadgeStyle.Light">
                            Sem inscrição
                        </RadzenBadge>
                    }
                </div>

                @if (MyRow?.IsBooked == true)
                {
                    <RadzenButton Text="Cancelar inscrição"
                                  ButtonStyle="ButtonStyle.Danger"
                                  Click="@Cancel" />
                }
                else
                {
                    <RadzenButton Text="Inscrever-me"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Click="@Join" />
                }

            </RadzenStack>

        </RadzenCard>
    }

    <RadzenStack Orientation="Orientation.Horizontal"
                 JustifyContent="JustifyContent.End"
                 Gap="1rem">

        <RadzenButton Text="Fechar"
                      ButtonStyle="ButtonStyle.Light"
                      Click="@Close" />

        @if (CanEditAttendance)
        {
            <RadzenButton Text="Guardar"
                          Icon="save"
                          ButtonStyle="ButtonStyle.Primary"
                          Click="@Save" />
        }

    </RadzenStack>

</RadzenStack>


@code {

    [Parameter] public int LessonId { get; set; }

    private LessonAttendanceDto Model = new();

    private LessonAttendanceUserDto? MyRow;

    private string? _userId;
    private string? _role;

    private bool CanEditAttendance =>
        _role is StaticRole.Admin or StaticRole.Teacher;

    private bool IsStudent =>
        _role == StaticRole.Student;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = auth.User;

        _userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        _role = user.FindFirst(ClaimTypes.Role)?.Value;

        await Load();
    }

    private async Task Load()
    {
        Model = await LessonService.GetAttendanceAsync(LessonId);

        MyRow = Model.Students
        .FirstOrDefault(x => x.UserId == _userId);
    }

    // TEACHER / ADMIN SAVE
    private async Task Save()
    {
        await LessonService.UpdateAttendanceAsync(Model);
        DialogService.Close(true);
    }

    // STUDENT JOIN
    private async Task Join()
    {
        await LessonService.BookLessonAsync(LessonId, _userId!);
        await Load();
    }

    // STUDENT CANCEL
    private async Task Cancel()
    {
        await LessonService.CancelBookingAsync(LessonId, _userId!);
        await Load();
    }

    private void Close()
        => DialogService.Close(false);
}
