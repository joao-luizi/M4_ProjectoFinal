@page "/admin/horses"
@using Microsoft.AspNetCore.Authorization
@using RepositoryLibrary.Features.Horses
@using RepositoryLibrary.Features.Horses.DTOs
@using RepositoryLibrary.Features.Horses.Interfaces
@using RepositoryLibrary.Shared.Enums
@using RideReady.Components.Features.Horses.Modals
@inject IHorseService HorseService
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Administrator")]

<h3 class="text-3xl font-bold mb-2">Gestão de Cavalos</h3>
<p class="text-muted mb-6">Lista e gestão dos cavalos da escola.</p>

@if (overview is null)
{
    <p>Loading...</p>
}
else
{
    @if (showForm)
    {
        <HorseForm Horse="editingHorse"
                   Mode="formMode"
                   OnSave="HandleHorseSave"
                   OnCancel="CloseForm" />
    }
    <!-- OVERVIEW -->
    <div class="grid grid-cols-3 gap-4 mb-6">
        <div class="card">
            <h4>Total</h4>
            <p>@overview.TotalHorses</p>
        </div>

        <div class="card">
            <h4>Escola</h4>
            <p>@overview.SchoolHorses</p>
        </div>

        <div class="card">
            <h4>Privados</h4>
            <p>@overview.PrivateHorses</p>
        </div>
    </div>

    <!-- LIST -->
    <div class="flex justify-between items-center mb-4">
        <h4>Lista de Cavalos</h4>

        <RadzenButton Text="Novo Cavalo"
                      Icon="add"
                      ButtonStyle="ButtonStyle.Primary"
                      Click="CreateHorse" />
    </div>
    <RadzenDataGrid Data="@overview.Horses" TItem="HorseListItemDto" Class="w-100">
        <Columns>

            <RadzenDataGridColumn TItem="HorseListItemDto" Property="HorseId" Title="ID" />

            <RadzenDataGridColumn TItem="HorseListItemDto" Property="Name" Title="Nome" />

            <RadzenDataGridColumn TItem="HorseListItemDto" Property="Breed" Title="Raça" />

            <RadzenDataGridColumn TItem="HorseListItemDto" Title="Idade">
                <Template Context="h">
                    @h.Age
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="HorseListItemDto" Title="Propriedade">
                <Template Context="h">
                    @h.Ownership
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="HorseListItemDto" Title="Ações">
                <Template Context="h">
                    <RadzenButton Icon="visibility"
                                  ButtonStyle="ButtonStyle.Info"
                                  Size="ButtonSize.Small"
                                  Click="@(() => ViewHorse(h.HorseId))" />

                    <RadzenButton Icon="edit"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Size="ButtonSize.Small"
                                  Click="@(() => EditHorse(h.HorseId))" />

                    <RadzenButton Icon="delete"
                                  ButtonStyle="ButtonStyle.Danger"
                                  Size="ButtonSize.Small"
                                  Disabled="true" />
                </Template>
            </RadzenDataGridColumn>

        </Columns>
    </RadzenDataGrid>
}

@code {
    private HorseOverviewDto? overview;

    private HorseEditDto? editingHorse;
    private bool showForm;
    private ModalFormMode formMode;
    protected override async Task OnInitializedAsync()
    {
        overview = await HorseService.GetHorseOverviewAsync();
        formMode = ModalFormMode.None;
    }

    private async Task ViewHorse(int id)
    {
        editingHorse = await HorseService.GetHorseEditDtoAsync(id);
        formMode = ModalFormMode.View;
        showForm = true;
    }

    private async Task EditHorse(int id)
    {
        editingHorse = await HorseService.GetHorseEditDtoAsync(id);
        formMode = ModalFormMode.Edit;
        showForm = true;
    }

    private async Task HandleHorseSave(HorseEditDto dto)
    {
        await HorseService.SaveHorseAsync(dto);

        overview = await HorseService.GetHorseOverviewAsync();

        showForm = false;

        editingHorse = null;
    }

    private void CreateHorse()
    {
        editingHorse = new HorseEditDto
        {
            DateOfBirth = DateTime.Today
        };
        formMode = ModalFormMode.Create;
        showForm = true;

    }
    private void CloseForm()
    {
        showForm = false;
        editingHorse = null;
        formMode = ModalFormMode.None;
    }
}
