@page "/admin/horses"
@using Microsoft.AspNetCore.Authorization
@using RepositoryLibrary.Features.Horses
@using RepositoryLibrary.Features.Horses.DTOs
@using RepositoryLibrary.Features.Horses.Interfaces
@using RepositoryLibrary.Features.Schools.DTOs
@using RepositoryLibrary.Features.Schools.Interfaces
@using RepositoryLibrary.Features.Users.DTOs
@using RepositoryLibrary.Features.Users.Interfaces
@using RepositoryLibrary.Shared.Enums
@using RideReady.Components.Features.Horses.Modals
@inject IHorseService HorseService
@inject ISchoolService SchoolService
@inject IUserService UserService
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Administrator")]

@if (overview is null)
{
    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
}
else
{
    @if (showForm)
    {
        <HorseForm Horse="editingHorse"
                   Mode="formMode"
                   Schools="schools"
                   Students = "students"
                   OnSave="HandleHorseSave"
                   OnCancel="CloseForm" />


    }
    else
    {
        <RadzenStack Gap="20px">

            <!-- TITLE -->
            <RadzenText TextStyle="TextStyle.H4">
                Gestão de Cavalos
            </RadzenText>

            <RadzenText TextStyle="TextStyle.Body2">
                Lista e gestão dos cavalos da escola.
            </RadzenText>

            <!-- OVERVIEW -->
            <RadzenRow Gap="16px">

                <RadzenColumn Size="4">
                    <RadzenCard>
                        <RadzenText TextStyle="TextStyle.Subtitle2">Total</RadzenText>
                        <RadzenText TextStyle="TextStyle.H5">@overview.TotalHorses</RadzenText>
                    </RadzenCard>
                </RadzenColumn>

                <RadzenColumn Size="4">
                    <RadzenCard>
                        <RadzenText TextStyle="TextStyle.Subtitle2">Escola</RadzenText>
                        <RadzenText TextStyle="TextStyle.H5">@overview.SchoolHorses</RadzenText>
                    </RadzenCard>
                </RadzenColumn>

                <RadzenColumn Size="4">
                    <RadzenCard>
                        <RadzenText TextStyle="TextStyle.Subtitle2">Privados</RadzenText>
                        <RadzenText TextStyle="TextStyle.H5">@overview.PrivateHorses</RadzenText>
                    </RadzenCard>
                </RadzenColumn>

            </RadzenRow>

            <!-- HEADER -->
            <RadzenStack Orientation="Orientation.Horizontal"
                         JustifyContent="JustifyContent.SpaceBetween"
                         AlignItems="AlignItems.Center">

                <RadzenText TextStyle="TextStyle.H6">
                    Lista de Cavalos
                </RadzenText>

                <RadzenButton Text="Novo Cavalo"
                              Icon="add"
                              ButtonStyle="ButtonStyle.Primary"
                              Click="CreateHorse" />

            </RadzenStack>

            <!-- GRID -->
            <RadzenDataGrid Data="@overview.Horses"
                            TItem="HorseListItemDto"
                            AllowPaging="true"
                            PageSize="10"
                            AllowSorting="true"
                            Class="w-100">

                <Columns>

                    <RadzenDataGridColumn TItem="HorseListItemDto"
                                          Property="HorseId"
                                          Title="ID" />

                    <RadzenDataGridColumn TItem="HorseListItemDto"
                                          Property="Name"
                                          Title="Nome" />

                    <RadzenDataGridColumn TItem="HorseListItemDto"
                                          Property="Breed"
                                          Title="Raça" />

                    <RadzenDataGridColumn TItem="HorseListItemDto"
                                          Title="Idade">
                        <Template Context="h">
                            @h.Age
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="HorseListItemDto"
                                          Title="Propriedade">
                        <Template Context="h">
                            @h.Ownership
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="HorseListItemDto"
                                          Title="Ações">
                        <Template Context="h">

                            <RadzenButton Icon="visibility"
                                          ButtonStyle="ButtonStyle.Info"
                                          Size="ButtonSize.Small"
                                          Click="@(() => ViewHorse(h.HorseId))" />

                            <RadzenButton Icon="edit"
                                          ButtonStyle="ButtonStyle.Primary"
                                          Size="ButtonSize.Small"
                                          Click="@(() => EditHorse(h.HorseId))" />

                            <RadzenButton Icon="delete"
                                          ButtonStyle="ButtonStyle.Danger"
                                          Size="ButtonSize.Small"
                                          Disabled="true" />

                        </Template>
                    </RadzenDataGridColumn>

                </Columns>

            </RadzenDataGrid>

        </RadzenStack>
    }
}

@code {
    private HorseOverviewDto? overview;

    private HorseEditDto? editingHorse;
    private bool showForm;

    private List<SchoolListDto> schools = new();
    private List<AdminUserListItemDto> students = new();
    private ModalFormMode formMode;

    protected override async Task OnInitializedAsync()
    {
        overview = await HorseService.GetHorseOverviewAsync();
        schools = await SchoolService.GetSchoolsListAsync();
        students = await UserService.GetUserListItemsAsync();
        formMode = ModalFormMode.None;
    }

    private async Task Refresh()
    {
        overview = await HorseService.GetHorseOverviewAsync();
    }

    private async Task ViewHorse(int id)
    {
        editingHorse = await HorseService.GetHorseEditDtoAsync(id);
        formMode = ModalFormMode.View;
        showForm = true;
    }

    private async Task EditHorse(int id)
    {
        editingHorse = await HorseService.GetHorseEditDtoAsync(id);
        formMode = ModalFormMode.Edit;
        showForm = true;
    }

    private void CreateHorse()
    {
        editingHorse = new HorseEditDto
        {
            DateOfBirth = DateTime.Today,
            SchoolId = schools.FirstOrDefault()?.SchoolId ?? 0
        };

        formMode = ModalFormMode.Create;
        showForm = true;
    }

    private async Task HandleHorseSave(HorseEditDto dto)
    {
        await HorseService.SaveHorseAsync(dto);

        await Refresh();

        showForm = false;
        editingHorse = null;
    }

    private void CloseForm()
    {
        showForm = false;
        editingHorse = null;
        formMode = ModalFormMode.None;
    }
}