@using Microsoft.AspNetCore.Components.Forms
@using Radzen
@using RepositoryLibrary.Features.Horses.DTOs
@using RepositoryLibrary.Features.Schools.DTOs
@using RepositoryLibrary.Features.Users.DTOs
@using RepositoryLibrary.Shared.Enums

@if (Horse is null)
{
    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
}
else
{
    <RadzenTemplateForm TItem="HorseEditDto"
                        Data="@Horse"
                        Submit="@OnSubmit">

        <RadzenFieldset Text="Horse Photo">

            <div style="display:flex; gap:16px; align-items:center;">

                <img src="@(previewImage ?? Horse.PhotoPath ?? "/Images/default_horse.png")"
                     style="width:120px;height:120px;border-radius:8px;object-fit:cover;" />

                @if (Mode != ModalFormMode.View)
                {
                    <InputFile OnChange="@OnFileSelectedHandler"
                               accept=".jpg,.jpeg,.png" />
                }

            </div>

        </RadzenFieldset>

        <RadzenFieldset Text="Details">

            <RadzenStack Gap="12px">

                <RadzenTextBox @bind-Value="Horse.Name"
                               Disabled="@(Mode == ModalFormMode.View)"
                               Placeholder="Name" />

                <RadzenTextBox @bind-Value="Horse.Breed"
                               Disabled="@(Mode == ModalFormMode.View)"
                               Placeholder="Breed" />

                <RadzenDatePicker @bind-Value="Horse.DateOfBirth"
                                  Disabled="@(Mode == ModalFormMode.View)" />

                <RadzenDropDown @bind-Value="Horse.SchoolId"
                                Data="@Schools"
                                TextProperty="SchoolName"
                                ValueProperty="SchoolId"
                                Placeholder="Select School"
                                Disabled="@(Mode == ModalFormMode.View)"
                                Style="width:100%" />

                <RadzenDropDown Data="@Students"
                                TextProperty="FullName"
                                ValueProperty="Id"
                                @bind-Value="Horse.OwnerUserId"
                                AllowClear="true"
                                Placeholder="Cavalo da escola"
                                Disabled="@(Mode == ModalFormMode.View)" 
                                />

            </RadzenStack>

        </RadzenFieldset>

        <div style="margin-top:16px; display:flex; gap:8px; justify-content:flex-end;">

            @if (Mode != ModalFormMode.View)
            {
                <RadzenButton ButtonType="ButtonType.Submit"
                              Text="Save"
                              Icon="save"
                              ButtonStyle="ButtonStyle.Primary" />
            }

            <RadzenButton Text="Close"
                          Icon="close"
                          ButtonStyle="ButtonStyle.Light"
                          Click="Cancel" />

        </div>

    </RadzenTemplateForm>
}

@code {

    private string? previewImage;

    [Parameter] public List<AdminUserListItemDto> Students { get; set; } = [];

    [Parameter] public List<SchoolListDto> Schools { get; set; } = new();

    [Parameter] public HorseEditDto? Horse { get; set; }

    [Parameter] public ModalFormMode Mode { get; set; }

    [Parameter] public EventCallback<HorseEditDto> OnSave { get; set; }

    [Parameter] public EventCallback OnCancel { get; set; }

    [Parameter] public EventCallback<IBrowserFile?> OnFileSelected { get; set; }


    private async Task OnFileSelectedHandler(InputFileChangeEventArgs e)
    {
        var file = e.File;

        Horse.NewPhoto = file;

        await using var stream = file.OpenReadStream(5 * 1024 * 1024);

        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);

        var buffer = ms.ToArray();

        previewImage = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";

        await OnFileSelected.InvokeAsync(file);
    }


    private async Task Cancel()
    {
        await OnCancel.InvokeAsync();
    }

    private async Task OnSubmit()
    {
        if (Mode == ModalFormMode.View)
            return;

        if (Horse is null)
            return;

        await OnSave.InvokeAsync(Horse);
    }
}