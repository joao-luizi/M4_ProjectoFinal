@using RepositoryLibrary.Features.Products
@using RepositoryLibrary.Features.Products.Interfaces
@using RepositoryLibrary.Features.Purchases.DTOs
@using RepositoryLibrary.Features.Purchases.Enums
@using RepositoryLibrary.Features.Purchases.Interfaces
@using RideReady.Components.Features.Purchases.Components

@inject IProductService ProductService
@inject IPurchaseService PurchaseService

<h3>Create Purchase</h3>

@if (_loading)
{
    <p>Loading...</p>
}
else
{
    <RadzenStack Gap="1rem">

        <!-- TABS -->
        <RadzenTabs>
            
            <!-- SUBSCRIPTIONS -->
            <RadzenTabsItem Text="Subscriptions">
                @foreach (var p in _subscriptionProducts)
                {
                    <RadzenRow AlignItems="AlignItems.Center" Gap="1rem">

                        <RadzenColumn Size="6">
                            <b>@p.Name</b>
                        </RadzenColumn>

                        <RadzenColumn Size="3">
                            @p.Price.ToString("0.00") €
                        </RadzenColumn>

                        <RadzenColumn Size="3">
                            <RadzenButton Icon="add"
                                          Size="ButtonSize.Small"
                                          Click="@(() => AddSubscription(p))" />
                        </RadzenColumn>

                    </RadzenRow>
                }
            </RadzenTabsItem>

            <!-- CREDIT PACKS -->
            <RadzenTabsItem Text="Credits">
                @foreach (var p in _creditProducts)
                {
                    <RadzenRow AlignItems="AlignItems.Center" Gap="1rem">

                        <RadzenColumn Size="6">
                            <b>@p.Name</b>
                        </RadzenColumn>

                        <RadzenColumn Size="3">
                            @p.Price.ToString("0.00") €
                        </RadzenColumn>

                        <RadzenColumn Size="3">
                            <RadzenNumeric TValue="int"
                                           Min="0"
                                           @bind-Value="p.Quantity"
                                           Style="width:100%" />
                        </RadzenColumn>

                    </RadzenRow>
                }
            </RadzenTabsItem>

        </RadzenTabs>

        <!-- CART -->
        <CartPreview Lines="@_cartLines"
                     LinesChanged="@OnCartChanged" />

        <!-- ACTIONS -->
        <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem">
            <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Click="@Close" />
            <RadzenButton Text="Create"
                          Icon="payment"
                          ButtonStyle="ButtonStyle.Primary"
                          Click="@Create" />
        </RadzenStack>

    </RadzenStack>
}

@code {

    [Parameter] public string StudentId { get; set; } = string.Empty;
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private List<CreatePurchaseLineDto> _cartLines = [];

    private bool _loading = true;

    private List<ProductVm> _subscriptionProducts = [];
    private List<ProductVm> _creditProducts = [];


    protected override async Task OnInitializedAsync()
    {
        var products = await ProductService.GetAll();

        _subscriptionProducts = products
            .Where(p => p.Entitlements.Any(e => e.WeeklyFrequency > 0))
            .Select(p => new ProductVm
            {
                ProductId = p.Id,
                Name = p.Name,
                Price = p.Price
            })
            .ToList();

        _creditProducts = products
            .Where(p => p.Entitlements.Any(e => e.CreditsGranted > 0))
            .Select(p => new ProductVm
            {
                ProductId = p.Id,
                Name = p.Name,
                Price = p.Price
            })
            .ToList();

        _loading = false;
    }

    private void AddSubscription(ProductVm p)
    {
        _cartLines.Add(new CreatePurchaseLineDto
        {
            ProductId = p.ProductId,
            ProductName = p.Name,
            UnitPrice = p.Price,
            Quantity = 1,
            Kind = PurchaseLineKind.Subscription
        });
    }

    private async Task Create()
    {
        if (!_cartLines.Any())
            return;

        var dto = new CreatePurchaseDto
        {
            UserId = StudentId,
            PaymentReceived = true,
            Lines = _cartLines
        };

        await PurchaseService.CreatePurchaseAsync(dto);

        await OnSaved.InvokeAsync();
    }

    private async Task Close()
    {
        await OnClose.InvokeAsync();
    }

    private void OnCartChanged(List<CreatePurchaseLineDto> lines)
    {
        _cartLines = lines;
    }

    private void AddToCart(ProductVm p)
    {
        if (p.Quantity <= 0)
            return;

        var existing = _cartLines
            .FirstOrDefault(x => x.ProductId == p.ProductId);

        if (existing is not null)
        {
            existing.Quantity += p.Quantity;
            return;
        }

        _cartLines.Add(new CreatePurchaseLineDto
        {
            ProductId = p.ProductId,
            ProductName = p.Name,
            UnitPrice = p.Price,
            Quantity = p.Quantity,
            Kind = PurchaseLineKind.CreditPack
        });

        p.Quantity = 0;
    }
}
