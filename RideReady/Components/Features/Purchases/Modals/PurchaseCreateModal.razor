@using RepositoryLibrary.Features.Products
@using RepositoryLibrary.Features.Products.Interfaces
@using RepositoryLibrary.Features.Purchases.DTOs
@using RepositoryLibrary.Features.Purchases.Enums
@using RepositoryLibrary.Features.Purchases.Interfaces
@using RideReady.Components.Features.Purchases.Components

@inject IProductService ProductService
@inject IPurchaseService PurchaseService
@inject NotificationService NotificationService



@if (_loading)
{
    <p>Loading...</p>
}
else
{


    <RadzenStack Gap="1rem">

        <RadzenText Text="Create Purchase" TextStyle="TextStyle.H5" />

        @if (!string.IsNullOrWhiteSpace(StudentName))
        {
            <p>Student: <b>@StudentName</b></p>
        }
       
        <RadzenAccordion>
            <Items>
                <RadzenAccordionItem Text="Subscriptions">
                @foreach (var p in _subscriptionProducts)
                {
                    <RadzenRow AlignItems="AlignItems.Center" Gap="1rem">

                            <RadzenColumn Size="6">
                                <b>@p.Name</b>
                                <br />
                                @p.Price.ToString("0.00") €/mês
                            </RadzenColumn>

                            <RadzenColumn Size="4">

                                <small>
                                    Início: @SubscriptionStart.ToString("dd/MM/yyyy")
                                </small>

                                <br />

                                <small>
                                    Fim: @GetSubscriptionEnd(p).ToString("dd/MM/yyyy")
                                </small>

                                <br />

                                <small>
                                    Meses: @GetSubscriptionMonths(p)
                                </small>

                            </RadzenColumn>

                            <RadzenColumn Size="2">

                                <RadzenButton Icon="remove"
                                              Click="@(() => AddSubscription(p, -1))" />

                                <RadzenButton Icon="add"
                                              Click="@(() => AddSubscription(p, 1))" />

                            </RadzenColumn>

                    </RadzenRow>
                }
                    
                </RadzenAccordionItem>

                <RadzenAccordionItem Text="Credits">
                @foreach (var p in _creditProducts)
                {
                    <RadzenRow AlignItems="AlignItems.Center" Gap="1rem">

                        <RadzenColumn Size="6">
                            <b>@p.Name</b>
                        </RadzenColumn>

                        <RadzenColumn Size="3">
                            @p.Price.ToString("0.00") €
                        </RadzenColumn>

                        <RadzenColumn Size="3">
                                <RadzenColumn Size="3">
                                    <RadzenButton Icon="remove"
                                                  Size="ButtonSize.Small"
                                                  Click="@(() => AddCredit(p, -1))" />

                                    <RadzenButton Icon="add"
                                                  Size="ButtonSize.Small"
                                                  Click="@(() => AddCredit(p, +1))" />
                                </RadzenColumn>
                        </RadzenColumn>

                    </RadzenRow>
                }
                    
                </RadzenAccordionItem>
            </Items>
        </RadzenAccordion>
           

        <!-- CART -->
        <CartPreview Lines="@_cartLines"
                     LinesChanged="@OnCartChanged" />

        
        <!-- ACTIONS -->
        <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem">
            <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Click="@Close" />
            <RadzenButton Text="Create"
                          Icon="payment"
                          ButtonStyle="ButtonStyle.Primary"
                          Click="@Create" />

            <RadzenCheckBox @bind-Value="_paymentReceived" />

            <RadzenLabel Text="Payment received" />
        </RadzenStack>

    </RadzenStack>
}

@code {

    [Parameter] public string StudentId { get; set; } = string.Empty;
    [Parameter] public string StudentName { get; set; } = string.Empty;
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    private bool _paymentReceived = true;
    private List<CreatePurchaseLineDto> _cartLines = [];

    private bool _loading = true;

    private List<ProductVm> _subscriptionProducts = [];
    private List<ProductVm> _creditProducts = [];


    private DateOnly SubscriptionStart =>
    new(DateTime.Today.Year,
        DateTime.Today.Month,
        1);

    private int GetSubscriptionMonths(ProductVm product)
    {
        return _cartLines
            .FirstOrDefault(x =>
                x.ProductId == product.ProductId &&
                x.Kind == PurchaseLineKind.Subscription)
            ?.Months ?? 0;
    }

    private DateOnly GetSubscriptionEnd(ProductVm product)
    {
        var line = _cartLines.FirstOrDefault(x =>
            x.ProductId == product.ProductId &&
            x.Kind == PurchaseLineKind.Subscription);

        var months = line?.Months ?? 0;

        if (months <= 0)
            return SubscriptionStart;

        return SubscriptionStart
            .AddMonths(months)
            .AddDays(-1);
    }

    protected override async Task OnInitializedAsync()
    {
        var products = await ProductService.GetAll();

        _subscriptionProducts = products
            .Where(p => p.Entitlements.Any(e => e.WeeklyFrequency > 0))
            .Select(p => new ProductVm
            {
                ProductId = p.Id,
                Name = p.Name,
                Price = p.Price
            })
            .ToList();

        _creditProducts = products
            .Where(p => p.Entitlements.Any(e => e.CreditsGranted > 0))
            .Select(p => new ProductVm
            {
                ProductId = p.Id,
                Name = p.Name,
                Price = p.Price
            })
            .ToList();

        _loading = false;
    }

    private void AddSubscription(ProductVm p, int delta)
    {
        var line = _cartLines
            .FirstOrDefault(x => x.ProductId == p.ProductId &&
                                  x.Kind == PurchaseLineKind.Subscription);

        if (line is null)
        {
            if (delta <= 0) return;

            _cartLines.Add(NewLine(p, delta));
            return;
        }

        var newValue = (line.Months ?? 0) + delta;

        if (newValue <= 0)
        {
            _cartLines.Remove(line);
            return;
        }

        line.Months = newValue;
    }

    private CreatePurchaseLineDto NewLine(ProductVm p, int months) => new()
    {
        ProductId = p.ProductId,
        ProductName = p.Name,
        UnitPrice = p.Price,
        Kind = PurchaseLineKind.Subscription,
        Months = months
    };

    private async Task Create()
    {
        if (!_cartLines.Any())
            return;

        var dto = new CreatePurchaseDto
        {
            UserId = StudentId,
            PaymentReceived = _paymentReceived,
            Lines = _cartLines
        };

        try
        {
            await PurchaseService.CreatePurchaseAsync(dto);

            await OnSaved.InvokeAsync();
        }
        catch
        {
            NotificationService.Notify(
             NotificationSeverity.Error,
             "Purchase failed",
             "An error occurred while creating the purchase.");
        }

    }

    private async Task Close()
    {
        await OnClose.InvokeAsync();
    }

    private void OnCartChanged(List<CreatePurchaseLineDto> lines)
    {
        _cartLines = lines;
    }

    private void AddCredit(ProductVm p, int delta)
    {
        var existing = _cartLines
            .FirstOrDefault(x =>
                x.ProductId == p.ProductId &&
                x.Kind == PurchaseLineKind.CreditPack);

        if (existing is null)
        {
            if (delta <= 0)
                return;

            _cartLines.Add(new CreatePurchaseLineDto
            {
                ProductId = p.ProductId,
                ProductName = p.Name,
                UnitPrice = p.Price,
                Kind = PurchaseLineKind.CreditPack,
                Quantity = delta
            });

            return;
        }

        existing.Quantity += delta;

        // 🧯 regra de negócio: não pode ser <= 0
        if (existing.Quantity <= 0)
        {
            _cartLines.Remove(existing);
        }
    }

    
}
